@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <div class="card shadow border-0 rounded-3">

                <!-- Header -->
                <div class="card-header bg-dark text-white text-center py-3">
                    <h3 class="mb-0">
                        <i class="bi bi-person-plus me-2"></i>Register
                    </h3>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    <form id="registerForm" class="row g-4" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <!-- ACCOUNT INFO -->
                        <h6 class="text-muted border-bottom pb-2">Account Information</h6>

                        <div class="form-floating col-12">
                            <input asp-for="Input.Name" class="form-control" placeholder="Full Name" />
                            <label asp-for="Input.Name"></label>
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>

                        <div class="form-floating col-12">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Input.Email"></label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating col-md-6">
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Password" />
                            <label asp-for="Input.Password"></label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-floating col-md-6">
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirm Password" />
                            <label asp-for="Input.ConfirmPassword"></label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <!-- ADDRESS -->
                      
                        <div class="form-floating col-12">
                            <input asp-for="Input.StreetAddress" id="street" class="form-control" placeholder="Street Address" />
                            <label asp-for="Input.StreetAddress"></label>
                            <span asp-validation-for="Input.StreetAddress" class="text-danger"></span>
                        </div>

                        <div id="addressSuggestions" class="list-group col-12"></div>

                        <div class="form-floating col-md-4">
                            <input asp-for="Input.City" id="city" class="form-control" readonly placeholder="City" />
                            <label asp-for="Input.City"></label>
                        </div>

                        <div class="form-floating col-md-4">
                            <input asp-for="Input.State" id="state" class="form-control" readonly placeholder="State" />
                            <label asp-for="Input.State"></label>
                        </div>

                        <div class="form-floating col-md-4">
                            <input asp-for="Input.PostalCode" id="postalCode" class="form-control" readonly placeholder="Postal Code" />
                            <label asp-for="Input.PostalCode">Postal Code</label>
                        </div>

                        <!-- CONTACT -->
                       

                        <div class="form-floating col-md-12">
                            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Phone Number" />
                            <label asp-for="Input.PhoneNumber"></label>
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                     

                        <div class="col-md-6">
                            <label class="form-label text-muted"></label>
                            <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select">
                                <option disabled selected>- Select Role -</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-muted"></label>
                            <select asp-for="Input.CompanyId" id="Input_CompanyId" style="display:none;" asp-items="@Model.Input.CompanyList" class="form-select">
                                <option disabled selected>- Select Company -</option>
                            </select>
                        </div>

                        <div class="col-12 pt-3">
                            <button id="registerSubmit" type="submit" class="btn btn-dark w-100 btn-lg">
                                <i class="bi bi-person-plus me-1"></i> Register
                            </button>
                        </div>

                    </form>

                    <hr class="my-4" />

                    <!-- External Login -->
                    <div class="text-center">
                        <p class="text-muted mb-3">Or register with</p>

                        @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                        {
                            <p class="text-muted small">No external authentication services configured.</p>
                        }
                        else
                        {
                            <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                <div class="d-grid gap-2">
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-outline-dark" name="provider" value="@provider.Name">
                                            @provider.DisplayName
                                        </button>
                                    }
                                </div>
                            </form>
                        }
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/address_autocomlete.js"></script>

    <script>
        $(document).ready(function () {
            $('#Input_Role').change(function () {
                var selection = $('#Input_Role option:selected').text();
                if (selection == 'Company') {
                    $('#Input_CompanyId').show();
                } else {
                    $('#Input_CompanyId').hide();
                }
            });
        });
    </script>
}