@page
@model LoginModel

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">

        <div class="card shadow border-0 rounded-3">

            <!-- Header -->
            <div class="card-header bg-dark text-white text-center py-3">
                <h3 class="mb-0">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Log in
                </h3>
            </div>

            <!-- Body -->
            <div class="card-body p-4">

                <form id="account" method="post">

                    <p class="text-center text-muted mb-4">
                        Use your CartivaWeb account to continue
                    </p>

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Email -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email"
                               class="form-control"
                               autocomplete="username"
                               placeholder="name@example.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password"
                               class="form-control"
                               autocomplete="current-password"
                               placeholder="Password" />
                        <label asp-for="Input.Password">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- Remember Me -->
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>

                    <div class="d-grid mb-3">
                        <button id="login-submit" type="submit" class="btn btn-dark btn-lg">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Log in
                        </button>
                    </div>

                    <!-- Links -->
                    <div class="d-flex justify-content-between small mb-3">
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>

                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                            Register
                        </a>

                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">
                            Resend email
                        </a>
                    </div>

                    <hr />

                    <!-- External Login -->
                    <div class="text-center">

                        <p class="text-muted mb-3">Or sign in with</p>

                        @{
                            if ((Model.ExternalLogins?.Count ?? 0) == 0)
                            {
                                <p class="text-muted small">
                                    No external authentication services configured.
                                </p>
                            }
                            else
                            {
                                <form id="external-account"
                                      asp-page="./ExternalLogin"
                                      asp-route-returnUrl="@Model.ReturnUrl"
                                      method="post">

                                    <div class="d-grid gap-2">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit"
                                                    class="btn btn-outline-dark"
                                                    name="provider"
                                                    value="@provider.Name">
                                                @provider.DisplayName
                                            </button>
                                        }
                                    </div>

                                </form>
                            }
                        }

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}