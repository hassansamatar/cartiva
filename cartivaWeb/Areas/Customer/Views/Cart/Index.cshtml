@model IEnumerable<ShoppingCart>
@using System.Globalization
@using ApplicationUtility

@{
    ViewData["Title"] = "My Shopping Cart";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<style>
    /* Cart Page Styles */
    .cart-item {
        transition: all 0.3s ease;
    }
    .cart-item-removing {
        opacity: 0;
        transform: translateX(-20px);
    }
    .quantity-btn:active {
        transform: scale(0.95);
    }
    .loading-spinner-small {
        display: inline-block;
        width: 0.8rem;
        height: 0.8rem;
        border: 2px solid #fff;
        border-radius: 50%;
        border-top-color: transparent;
        animation: spin 0.6s linear infinite;
    }
    /* Keyframes must be inside style tag */
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
    .toast-container {
        position: fixed;
        top: 80px;
        right: 20px;
        z-index: 1055;
    }
    .cart-table th, .cart-table td {
        vertical-align: middle;
    }
    .quantity-input {
        width: 60px;
        text-align: center;
    }
</style>

<div class="container mt-4">
    <!-- Toast Container for Notifications -->
    <div class="toast-container"></div>

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Shopping Cart</li>
        </ol>
    </nav>

    <h2 class="mb-4">
        <i class="bi bi-cart"></i> My Shopping Cart
        @if (Model.Any())
        {
            <span class="badge bg-primary ms-2" id="totalItemsBadge">@Model.Count() items</span>
        }
    </h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x" style="font-size: 4rem; color: #6c757d;"></i>
            <h4 class="mt-3">Your cart is empty</h4>
            <p class="text-muted">Looks like you haven't added any items to your cart yet.</p>
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
                <i class="bi bi-arrow-left"></i> Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle cart-table">
                <thead class="table-light">
                    <tr>
                        <th class="text-start" style="width: 35%">Product</th>
                        <th style="width: 20%">Variant</th>
                        <th style="width: 10%">Price</th>
                        <th style="width: 15%">Quantity</th>
                        <th style="width: 10%">Subtotal</th>
                        <th style="width: 10%">Actions</th>
                    </thead>
                <tbody id="cart-items-container">
                    @foreach (var item in Model)
                    {
                        <tr id="cart-item-@item.Id" class="cart-item" data-item-id="@item.Id" data-price="@item.ProductVariant.Price" data-stock="@item.ProductVariant.Stock">
                            <td class="text-start">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.ProductVariant.Product.ImageUrl))
                                    {
                                        <img src="@item.ProductVariant.Product.ImageUrl"
                                             alt="@item.ProductVariant.Product.Name"
                                             class="img-thumbnail me-3"
                                             style="width:70px;height:70px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="me-3 bg-light d-flex align-items-center justify-content-center"
                                             style="width:70px;height:70px; border-radius:5px;">
                                            <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                                        </div>
                                    }
                                    <div>
                                        <strong>@item.ProductVariant.Product.Name</strong>
                                        <br />
                                        <small class="text-muted">@item.ProductVariant.Product.Brand</small>
                                    </div>
                                </div>
                             </td>
                             <td>
                                <div class="d-flex flex-column align-items-center">
                                    <span class="badge mb-2"
                                          style="background-color: @GetColorCode(item.ProductVariant.Color);
                                                color: @GetTextColor(item.ProductVariant.Color);
                                                padding: 0.5rem 1rem;">
                                        <i class="bi bi-droplet me-1"></i> @item.ProductVariant.Color
                                    </span>
                                    @if (item.ProductVariant.SizeValue != null)
                                    {
                                        <span class="badge bg-secondary" style="padding: 0.5rem 1rem;">
                                            <i class="bi bi-rulers me-1"></i> @item.ProductVariant.SizeValue.DisplayText
                                        </span>
                                        @if (!string.IsNullOrEmpty(item.ProductVariant.SizeValue.Description))
                                        {
                                            <small class="text-muted mt-1">@item.ProductVariant.SizeValue.Description</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="padding: 0.5rem 1rem;">
                                            <i class="bi bi-dash"></i> No Size
                                        </span>
                                    }
                                </div>
                             </td>
                             <td class="price-cell">
                                <strong>@item.ProductVariant.Price.ToString("C", culture)</strong>
                                @if (item.ProductVariant.Stock <= 5)
                                {
                                    <br />
                                    <small class="text-danger">Only @item.ProductVariant.Stock left!</small>
                                }
                             </td>
                             <td>
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary decrement-btn" data-item-id="@item.Id" @(item.Count <= 1 ? "disabled" : "")>
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <span class="px-3 py-1 border rounded bg-light quantity-display" id="qty-@item.Id">@item.Count</span>
                                    <button type="button" class="btn btn-sm btn-outline-secondary increment-btn" data-item-id="@item.Id" @(item.Count >= item.ProductVariant.Stock ? "disabled" : "")>
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                                <div class="mt-2 d-flex justify-content-center">
                                    <div class="input-group input-group-sm" style="width: 110px;">
                                        <input type="number" class="form-control text-center quantity-input" id="qty-input-@item.Id" value="@item.Count" min="1" max="@item.ProductVariant.Stock" />
                                        <button type="button" class="btn btn-outline-primary update-qty-btn" data-item-id="@item.Id">
                                            <i class="bi bi-check"></i>
                                        </button>
                                    </div>
                                </div>
                             </td>
                             <td class="subtotal-cell" id="subtotal-@item.Id">
                                <strong class="text-primary">@((item.ProductVariant.Price * item.Count).ToString("C", culture))</strong>
                             </td>
                             <td>
                                <button type="button" class="btn btn-sm btn-outline-danger remove-item-btn" data-item-id="@item.Id" data-product-name="@item.ProductVariant.Product.Name">
                                    <i class="bi bi-trash"></i>
                                </button>
                             </td>
                         </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                     <tr>
                        <td colspan="4" class="text-end"><strong>Total:</strong></td>
                        <td colspan="2">
                            <h4 class="text-primary mb-0" id="cartTotal">
                                @Model.Sum(i => i.ProductVariant.Price * i.Count).ToString("C", culture)
                            </h4>
                        </td>
                     </tr>
                </tfoot>
             </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-4">
            <div>
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Continue Shopping
                </a>
                <button type="button" class="btn btn-outline-danger ms-2" id="clearCartBtn">
                    <i class="bi bi-trash"></i> Clear Cart
                </button>
            </div>
            <a asp-area="Customer" asp-controller="Order" asp-action="Checkout" class="btn btn-success btn-lg mt-3 mt-md-0">
                <i class="bi bi-credit-card"></i> Proceed to Checkout
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Helper Functions
            function formatCurrency(amount) {
                return new Intl.NumberFormat('nb-NO', {
                    style: 'currency',
                    currency: 'NOK'
                }).format(amount);
            }

            function showToast(message, type = 'success') {
                const bgColor = type === 'success' ? 'bg-success' : (type === 'error' ? 'bg-danger' : 'bg-warning');
                const icon = type === 'success' ? 'check-circle' : (type === 'error' ? 'exclamation-triangle' : 'info-circle');
                
                const toast = $(`
                    <div class="toast align-items-center text-white ${bgColor} border-0 show" role="alert" data-bs-autohide="true" data-bs-delay="3000">
                        <div class="d-flex">
                            <div class="toast-body">
                                <i class="bi bi-${icon} me-2"></i> ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                `);
                
                $('.toast-container').append(toast);
                
                setTimeout(() => {
                    toast.fadeOut(300, () => toast.remove());
                }, 3000);
            }

            function updateCartTotals() {
                let total = 0;
                let itemCount = 0;
                
                $('.cart-item').each(function() {
                    const price = parseFloat($(this).data('price'));
                    const qty = parseInt($(this).find('.quantity-display').text());
                    total += price * qty;
                    itemCount++;
                });
                
                $('#cartTotal').text(formatCurrency(total));
                $('#totalItemsBadge').text(itemCount + (itemCount === 1 ? ' item' : ' items'));
                
                if (typeof window.updateCartCount === 'function') {
                    window.updateCartCount();
                }
            }

            function updateSubtotal(itemId, newQty) {
                const price = $(`#cart-item-${itemId}`).data('price');
                const subtotal = price * newQty;
                $(`#subtotal-${itemId}`).html('<strong class="text-primary">' + formatCurrency(subtotal) + '</strong>');
            }

            // Increment Button
            $('.increment-btn').click(function() {
                const btn = $(this);
                const itemId = btn.data('item-id');
                const qtySpan = $(`#qty-${itemId}`);
                const currentQty = parseInt(qtySpan.text());
                const maxStock = parseInt($(`#cart-item-${itemId}`).data('stock'));
                
                if (currentQty < maxStock) {
                    const newQty = currentQty + 1;
                    btn.prop('disabled', true);
                    $(`#qty-input-${itemId}`).val(newQty);
                    
                    $.ajax({
                        url: '@Url.Action("Increment", "Cart")',
                        type: 'POST',
                        data: { id: itemId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(response) {
                            if (response.success) {
                                qtySpan.text(newQty);
                                updateSubtotal(itemId, newQty);
                                
                                if (newQty >= maxStock) btn.prop('disabled', true);
                                else btn.prop('disabled', false);
                                
                                if (newQty > 1) $(`[data-item-id="${itemId}"].decrement-btn`).prop('disabled', false);
                                
                                updateCartTotals();
                                showToast('Quantity updated');
                            } else {
                                showToast(response.message || 'Failed to update', 'error');
                                btn.prop('disabled', false);
                            }
                        },
                        error: function() {
                            showToast('Network error', 'error');
                            btn.prop('disabled', false);
                        }
                    });
                }
            });

            // Decrement Button
            $('.decrement-btn').click(function() {
                const btn = $(this);
                const itemId = btn.data('item-id');
                const qtySpan = $(`#qty-${itemId}`);
                const currentQty = parseInt(qtySpan.text());
                
                if (currentQty > 1) {
                    const newQty = currentQty - 1;
                    btn.prop('disabled', true);
                    $(`#qty-input-${itemId}`).val(newQty);
                    
                    $.ajax({
                        url: '@Url.Action("Decrement", "Cart")',
                        type: 'POST',
                        data: { id: itemId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(response) {
                            if (response.success) {
                                if (response.removed) {
                                    $(`#cart-item-${itemId}`).addClass('cart-item-removing').fadeOut(300, function() {
                                        $(this).remove();
                                        updateCartTotals();
                                        if ($('.cart-item').length === 0) location.reload();
                                        showToast('Item removed');
                                    });
                                } else {
                                    qtySpan.text(newQty);
                                    updateSubtotal(itemId, newQty);
                                    
                                    if (newQty <= 1) btn.prop('disabled', true);
                                    else btn.prop('disabled', false);
                                    
                                    const maxStock = $(`#cart-item-${itemId}`).data('stock');
                                    if (newQty < maxStock) $(`[data-item-id="${itemId}"].increment-btn`).prop('disabled', false);
                                    
                                    updateCartTotals();
                                    showToast('Quantity updated');
                                }
                            } else {
                                showToast(response.message || 'Failed to update', 'error');
                                btn.prop('disabled', false);
                            }
                        },
                        error: function() {
                            showToast('Network error', 'error');
                            btn.prop('disabled', false);
                        }
                    });
                }
            });

            // Update Quantity Button
            $('.update-qty-btn').click(function() {
                const btn = $(this);
                const itemId = btn.data('item-id');
                const input = $(`#qty-input-${itemId}`);
                const newQty = parseInt(input.val());
                const maxStock = parseInt(input.attr('max'));
                const minStock = parseInt(input.attr('min'));
                const currentQty = parseInt($(`#qty-${itemId}`).text());
                
                if (isNaN(newQty) || newQty < minStock) {
                    showToast(`Minimum quantity is ${minStock}`, 'warning');
                    input.val(currentQty);
                    return;
                }
                
                if (newQty > maxStock) {
                    showToast(`Only ${maxStock} available`, 'warning');
                    input.val(currentQty);
                    return;
                }
                
                if (newQty === currentQty) return;
                
                btn.prop('disabled', true);
                btn.html('<span class="loading-spinner-small"></span>');
                
                $.ajax({
                    url: '@Url.Action("UpdateCount", "Cart")',
                    type: 'POST',
                    data: { id: itemId, count: newQty, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function(response) {
                        if (response.success) {
                            if (response.removed) {
                                $(`#cart-item-${itemId}`).addClass('cart-item-removing').fadeOut(300, function() {
                                    $(this).remove();
                                    updateCartTotals();
                                    if ($('.cart-item').length === 0) location.reload();
                                    showToast('Item removed');
                                });
                            } else {
                                $(`#qty-${itemId}`).text(newQty);
                                updateSubtotal(itemId, newQty);
                                
                                $(`[data-item-id="${itemId}"].decrement-btn`).prop('disabled', newQty <= 1);
                                $(`[data-item-id="${itemId}"].increment-btn`).prop('disabled', newQty >= maxStock);
                                
                                updateCartTotals();
                                showToast('Quantity updated');
                            }
                        } else {
                            showToast(response.message || 'Failed to update', 'error');
                            input.val(currentQty);
                        }
                        btn.prop('disabled', false);
                        btn.html('<i class="bi bi-check"></i>');
                    },
                    error: function() {
                        showToast('Network error', 'error');
                        input.val(currentQty);
                        btn.prop('disabled', false);
                        btn.html('<i class="bi bi-check"></i>');
                    }
                });
            });

            // Remove Item
            $('.remove-item-btn').click(function() {
                const btn = $(this);
                const itemId = btn.data('item-id');
                const productName = btn.data('product-name');
                
                if (confirm(`Remove ${productName} from your cart?`)) {
                    btn.prop('disabled', true);
                    btn.html('<span class="loading-spinner-small"></span>');
                    
                    $.ajax({
                        url: '@Url.Action("Remove", "Cart")',
                        type: 'POST',
                        data: { id: itemId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(response) {
                            if (response.success) {
                                $(`#cart-item-${itemId}`).addClass('cart-item-removing').fadeOut(300, function() {
                                    $(this).remove();
                                    updateCartTotals();
                                    if ($('.cart-item').length === 0) location.reload();
                                    showToast(`${productName} removed`);
                                });
                            } else {
                                showToast(response.message || 'Failed to remove', 'error');
                                btn.prop('disabled', false);
                                btn.html('<i class="bi bi-trash"></i>');
                            }
                        },
                        error: function() {
                            showToast('Network error', 'error');
                            btn.prop('disabled', false);
                            btn.html('<i class="bi bi-trash"></i>');
                        }
                    });
                }
            });

            // Clear Cart
            $('#clearCartBtn').click(function() {
                if (confirm('Remove all items from your cart?')) {
                    const btn = $(this);
                    btn.prop('disabled', true);
                    btn.html('<span class="spinner-border spinner-border-sm"></span> Clearing...');
                    
                    $.ajax({
                        url: '@Url.Action("RemoveAll", "Cart")',
                        type: 'POST',
                        data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(response) {
                            if (response.success) {
                                showToast('Cart cleared');
                                setTimeout(() => location.reload(), 1000);
                            } else {
                                showToast(response.message || 'Failed to clear', 'error');
                                btn.prop('disabled', false);
                                btn.html('<i class="bi bi-trash"></i> Clear Cart');
                            }
                        },
                        error: function() {
                            showToast('Network error', 'error');
                            btn.prop('disabled', false);
                            btn.html('<i class="bi bi-trash"></i> Clear Cart');
                        }
                    });
                }
            });

            // Enter key on quantity input
            $('.quantity-input').keypress(function(e) {
                if (e.which === 13) {
                    $(this).closest('td').find('.update-qty-btn').click();
                }
            });
        });
    </script>
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}