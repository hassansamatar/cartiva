@model IEnumerable<ShoppingCart>
@using System.Globalization

@{
    ViewData["Title"] = "My Shopping Cart";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<!-- Toastr notifications will appear here -->

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Shopping Cart</li>
        </ol>
    </nav>

    <h2 class="mb-4">
        <i class="bi bi-cart"></i> My Shopping Cart
        @if (Model.Any())
        {
            <span class="badge bg-primary ms-2" id="totalItemsBadge">@Model.Count() items</span>
        }
    </h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x" style="font-size: 4rem; color: #6c757d;"></i>
            <h4 class="mt-3">Your cart is empty</h4>
            <p class="text-muted">Looks like you haven't added any items to your cart yet.</p>
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
                <i class="bi bi-arrow-left"></i> Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="cartTable">
                <thead class="table-light">
                    <tr>
                        <th class="text-start" style="width: 35%">Product</th>
                        <th style="width: 20%">Variant</th>
                        <th style="width: 10%">Price</th>
                        <th style="width: 15%">Quantity</th>
                        <th style="width: 10%">Subtotal</th>
                        <th style="width: 10%">Actions</th>
                    </tr>
                </thead>
                <tbody id="cartItemsContainer">
                    @foreach (var item in Model)
                    {
                        <tr id="cart-item-@item.Id" data-item-id="@item.Id" data-variant-id="@item.ProductVariantId" data-price="@item.ProductVariant.Price" data-stock="@item.ProductVariant.Stock">
                            <td class="text-start">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.ProductVariant.Product.ImageUrl))
                                    {
                                        <img src="@item.ProductVariant.Product.ImageUrl"
                                             alt="@item.ProductVariant.Product.Name"
                                             class="img-thumbnail me-3"
                                             style="width:70px;height:70px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="me-3 bg-light d-flex align-items-center justify-content-center"
                                             style="width:70px;height:70px; border-radius:5px;">
                                            <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                                        </div>
                                    }
                                    <div>
                                        <strong>@item.ProductVariant.Product.Name</strong>
                                        <br />
                                        <small class="text-muted">@item.ProductVariant.Product.Brand</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column align-items-center">
                                    <!-- Color Badge -->
                                    <span class="badge mb-2"
                                          style="background-color: @GetColorCode(item.ProductVariant.Color);
                                        color: @GetTextColor(item.ProductVariant.Color);
                                        padding: 0.5rem 1rem;">
                                        <i class="bi bi-droplet me-1"></i> @item.ProductVariant.Color
                                    </span>
                                    
                                    <!-- Size Display -->
                                    @if (item.ProductVariant.SizeValue != null)
                                    {
                                        <span class="badge bg-secondary" style="padding: 0.5rem 1rem;">
                                            <i class="bi bi-rulers me-1"></i>
                                            @item.ProductVariant.SizeValue.DisplayText
                                        </span>
                                        @if (!string.IsNullOrEmpty(item.ProductVariant.SizeValue.Description))
                                        {
                                            <small class="text-muted mt-1">@item.ProductVariant.SizeValue.Description</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="padding: 0.5rem 1rem;">
                                            <i class="bi bi-dash"></i> No Size
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="price-cell">
                                <strong>@item.ProductVariant.Price.ToString("C", culture)</strong>
                                <div class="stock-warning-@item.Id">
                                    @if (item.ProductVariant.Stock <= 5)
                                    {
                                        <small class="text-danger">Only @item.ProductVariant.Stock left!</small>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary decrement-btn"
                                            data-item-id="@item.Id"
                                        @(item.Count <= 1 ? "disabled" : "")>
                                        <i class="bi bi-dash"></i>
                                    </button>

                                    <span class="px-3 py-1 border rounded bg-light quantity-display" id="quantity-@item.Id">@item.Count</span>

                                    <button type="button" class="btn btn-sm btn-outline-secondary increment-btn"
                                            data-item-id="@item.Id"
                                        @(item.Count >= item.ProductVariant.Stock ? "disabled" : "")>
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                                
                                <!-- Update form for direct count input -->
                                <div class="mt-2 d-flex justify-content-center">
                                    <div class="input-group input-group-sm" style="width: 120px;">
                                        <input type="number" class="form-control text-center quantity-input"
                                               id="input-@item.Id"
                                               value="@item.Count"
                                               min="1" max="@item.ProductVariant.Stock"
                                               data-item-id="@item.Id" />
                                        <button class="btn btn-outline-primary update-quantity-btn"
                                                data-item-id="@item.Id">
                                            <i class="bi bi-check"></i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                            <td class="subtotal-cell" id="subtotal-@item.Id">
                                <strong class="text-primary">
                                    @((item.ProductVariant.Price * item.Count).ToString("C", culture))
                                </strong>
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger remove-item-btn"
                                        data-item-id="@item.Id"
                                        data-product-name="@item.ProductVariant.Product.Name">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end"><strong>Total:</strong></td>
                        <td colspan="2">
                            <h4 class="text-primary mb-0" id="cartTotal">
                                @Model.Sum(i => i.ProductVariant.Price * i.Count).ToString("C", culture)
                            </h4>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-4">
            <div>
                <a asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Continue Shopping
                </a>
                
                <button type="button" class="btn btn-outline-danger ms-2" id="clearCartBtn">
                    <i class="bi bi-trash"></i> Clear Cart
                </button>
            </div>

            <a asp-area="Customer"
                   asp-controller="Order"
                   asp-action="Checkout"
                   class="btn btn-success btn-lg mt-3 mt-md-0"
                   id="checkoutBtn">
                <i class="bi bi-credit-card"></i> Proceed to Checkout
            </a>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to remove <strong id="deleteProductName"></strong> from your cart?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="bi bi-trash"></i> Remove
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // ======================
            // VARIABLES
            // ======================
            let deleteItemId = null;
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

            // ======================
            // HELPER FUNCTIONS
            // ======================
            
            // Format currency helper
            function formatCurrency(amount) {
                return 'kr ' + amount.toFixed(2).replace('.', ',');
            }

            // Update cart total and item count
            function updateTotals() {
                let cartTotal = 0;
                $('.subtotal-cell').each(function() {
                    const subtotalText = $(this).text().replace('kr', '').replace(/\s/g, '').replace(',', '.');
                    const subtotal = parseFloat(subtotalText) || 0;
                    cartTotal += subtotal;
                });
                $('#cartTotal').text(formatCurrency(cartTotal));
                
                // Update items count
                const itemCount = $('.quantity-display').length;
                $('#totalItemsBadge').text(itemCount + (itemCount === 1 ? ' item' : ' items'));
                
                // Trigger navbar cart update
                if (typeof window.updateCartCount === 'function') {
                    window.updateCartCount();
                } else {
                    // Fallback: dispatch custom event
                    document.dispatchEvent(new CustomEvent('cartUpdated'));
                }
            }

            // Show toast message
            function showToast(message, type = 'success') {
                if (typeof toastr !== 'undefined') {
                    toastr[type](message);
                } else {
                    alert(message);
                }
            }

            // ======================
            // INCREMENT BUTTON
            // ======================
            $('.increment-btn').click(function() {
                const button = $(this);
                const itemId = button.data('item-id');
                const quantitySpan = $(`#quantity-${itemId}`);
                const currentQty = parseInt(quantitySpan.text());
                const maxStock = $(`#cart-item-${itemId}`).data('stock');
                
                if (currentQty < maxStock) {
                    button.prop('disabled', true);
                    
                    $.ajax({
                        url: '@Url.Action("Increment", "Cart")',
                        type: 'POST',
                        data: {
                            id: itemId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                const newQty = response.newCount;
                                
                                // Update UI
                                quantitySpan.text(newQty);
                                $(`#input-${itemId}`).val(newQty);
                                
                                // Update subtotal
                                const price = $(`#cart-item-${itemId}`).data('price');
                                const subtotal = price * newQty;
                                $(`#subtotal-${itemId}`).html('<strong class="text-primary">' + formatCurrency(subtotal) + '</strong>');
                                
                                // Enable/disable buttons
                                if (newQty >= maxStock) {
                                    button.prop('disabled', true);
                                } else {
                                    button.prop('disabled', false);
                                }
                                
                                if (newQty > 1) {
                                    $(`[data-item-id="${itemId}"].decrement-btn`).prop('disabled', false);
                                }
                                
                                // Update totals
                                updateTotals();
                                
                                // Show success message
                                showToast(response.message || 'Quantity updated');
                            } else {
                                showToast(response.message || 'Failed to update quantity', 'error');
                                button.prop('disabled', false);
                            }
                        },
                        error: function() {
                            showToast('Failed to update quantity', 'error');
                            button.prop('disabled', false);
                        }
                    });
                }
            });

            // ======================
            // DECREMENT BUTTON
            // ======================
            $('.decrement-btn').click(function() {
                const button = $(this);
                const itemId = button.data('item-id');
                const quantitySpan = $(`#quantity-${itemId}`);
                const currentQty = parseInt(quantitySpan.text());
                
                if (currentQty > 1) {
                    button.prop('disabled', true);
                    
                    $.ajax({
                        url: '@Url.Action("Decrement", "Cart")',
                        type: 'POST',
                        data: {
                            id: itemId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                if (response.removed) {
                                    // Item was removed (count became 0)
                                    $(`#cart-item-${itemId}`).fadeOut(300, function() {
                                        $(this).remove();
                                        
                                        if ($('#cartItemsContainer tr').length === 0) {
                                            location.reload();
                                        } else {
                                            updateTotals();
                                            showToast(response.message || 'Item removed');
                                        }
                                    });
                                } else {
                                    const newQty = response.newCount;
                                    
                                    // Update UI
                                    quantitySpan.text(newQty);
                                    $(`#input-${itemId}`).val(newQty);
                                    
                                    // Update subtotal
                                    const price = $(`#cart-item-${itemId}`).data('price');
                                    const subtotal = price * newQty;
                                    $(`#subtotal-${itemId}`).html('<strong class="text-primary">' + formatCurrency(subtotal) + '</strong>');
                                    
                                    // Enable/disable buttons
                                    if (newQty <= 1) {
                                        button.prop('disabled', true);
                                    } else {
                                        button.prop('disabled', false);
                                    }
                                    
                                    const maxStock = $(`#cart-item-${itemId}`).data('stock');
                                    if (newQty < maxStock) {
                                        $(`[data-item-id="${itemId}"].increment-btn`).prop('disabled', false);
                                    }
                                    
                                    // Update totals
                                    updateTotals();
                                    
                                    // Show success message
                                    showToast(response.message || 'Quantity updated');
                                }
                            } else {
                                showToast(response.message || 'Failed to update quantity', 'error');
                                button.prop('disabled', false);
                            }
                        },
                        error: function() {
                            showToast('Failed to update quantity', 'error');
                            button.prop('disabled', false);
                        }
                    });
                }
            });

            // ======================
            // UPDATE QUANTITY BUTTON
            // ======================
            $('.update-quantity-btn').click(function() {
                const button = $(this);
                const itemId = button.data('item-id');
                const input = $(`#input-${itemId}`);
                const newQty = parseInt(input.val());
                const maxStock = parseInt(input.attr('max'));
                const minStock = parseInt(input.attr('min'));
                
                if (isNaN(newQty) || newQty < minStock || newQty > maxStock) {
                    showToast(`Quantity must be between ${minStock} and ${maxStock}`, 'error');
                    input.val($(`#quantity-${itemId}`).text());
                    return;
                }
                
                button.prop('disabled', true);
                
                $.ajax({
                    url: '@Url.Action("UpdateCount", "Cart")',
                    type: 'POST',
                    data: {
                        id: itemId,
                        count: newQty,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            if (response.removed) {
                                $(`#cart-item-${itemId}`).fadeOut(300, function() {
                                    $(this).remove();
                                    
                                    if ($('#cartItemsContainer tr').length === 0) {
                                        location.reload();
                                    } else {
                                        updateTotals();
                                        showToast(response.message || 'Item removed');
                                    }
                                });
                            } else {
                                // Update UI
                                $(`#quantity-${itemId}`).text(newQty);
                                
                                // Update subtotal
                                const price = $(`#cart-item-${itemId}`).data('price');
                                const subtotal = price * newQty;
                                $(`#subtotal-${itemId}`).html('<strong class="text-primary">' + formatCurrency(subtotal) + '</strong>');
                                
                                // Update button states
                                const decrementBtn = $(`[data-item-id="${itemId}"].decrement-btn`);
                                const incrementBtn = $(`[data-item-id="${itemId}"].increment-btn`);
                                
                                decrementBtn.prop('disabled', newQty <= 1);
                                incrementBtn.prop('disabled', newQty >= maxStock);
                                
                                // Update totals
                                updateTotals();
                                
                                showToast(response.message || 'Quantity updated');
                            }
                        } else {
                            showToast(response.message || 'Failed to update quantity', 'error');
                            input.val($(`#quantity-${itemId}`).text());
                        }
                        button.prop('disabled', false);
                    },
                    error: function() {
                        showToast('Failed to update quantity', 'error');
                        input.val($(`#quantity-${itemId}`).text());
                        button.prop('disabled', false);
                    }
                });
            });

            // ======================
            // REMOVE ITEM (Show Modal)
            // ======================
            $('.remove-item-btn').click(function() {
                const button = $(this);
                deleteItemId = button.data('item-id');
                const productName = button.data('product-name');
                $('#deleteProductName').text(productName);
                deleteModal.show();
            });

            // ======================
            // CONFIRM DELETE
            // ======================
            $('#confirmDeleteBtn').click(function() {
                if (deleteItemId) {
                    const button = $(this);
                    button.prop('disabled', true);
                    
                    $.ajax({
                        url: '@Url.Action("Remove", "Cart")',
                        type: 'POST',
                        data: {
                            id: deleteItemId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                $(`#cart-item-${deleteItemId}`).fadeOut(300, function() {
                                    $(this).remove();
                                    
                                    if ($('#cartItemsContainer tr').length === 0) {
                                        location.reload();
                                    } else {
                                        updateTotals();
                                        showToast(response.message || 'Item removed');
                                    }
                                });
                            } else {
                                showToast(response.message || 'Failed to remove item', 'error');
                            }
                        },
                        error: function() {
                            showToast('Failed to remove item', 'error');
                        },
                        complete: function() {
                            deleteModal.hide();
                            deleteItemId = null;
                            button.prop('disabled', false);
                        }
                    });
                }
            });

            // ======================
            // CLEAR CART
            // ======================
            $('#clearCartBtn').click(function() {
                if (confirm('Are you sure you want to remove all items from your cart?')) {
                    const button = $(this);
                    button.prop('disabled', true);
                    
                    $.ajax({
                        url: '@Url.Action("RemoveAll", "Cart")',
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                showToast(response.message || 'Cart cleared');
                                setTimeout(() => location.reload(), 1000);
                            }
                        },
                        error: function() {
                            showToast('Failed to clear cart', 'error');
                            button.prop('disabled', false);
                        }
                    });
                }
            });

            // ======================
            // ENTER KEY ON INPUT
            // ======================
            $('.quantity-input').keypress(function(e) {
                if (e.which === 13) {
                    $(this).siblings('button').click();
                }
            });

            // ======================
            // INITIAL UPDATE
            // ======================
            updateTotals();
            
            console.log('Cart page loaded with AJAX functionality');
        });
    </script>
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}