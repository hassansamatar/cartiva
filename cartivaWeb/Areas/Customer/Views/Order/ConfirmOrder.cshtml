@model CheckoutVM
@using System.Globalization
@using ApplicationUtility
@using Models.Interfaces
@inject IQrCodeService QrCodeService

@{
    ViewData["Title"] = "Confirm Order";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    bool companyInactive = TempData["CompanyInactive"] != null;

    // Generate a placeholder QR code for preview
    var placeholderOrderId = 99999;
    var placeholderQrCodeBase64 = QrCodeService.GenerateOrderQrCode(placeholderOrderId);
    var placeholderTrackingUrl = Url.Action("Track", "Order", new { id = placeholderOrderId, area = "Customer" });
}

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Cart" asp-action="Index">Cart</a></li>
            <li class="breadcrumb-item"><a asp-action="Checkout">Checkout</a></li>
            <li class="breadcrumb-item active" aria-current="page">Confirm Order</li>
        </ol>
    </nav>

    <h2 class="mb-4">
        <i class="bi bi-check-circle"></i> Confirm Your Order
    </h2>

    <div class="row">
        <!-- SHIPPING INFO -->
        <div class="col-md-6">
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-truck"></i> Shipping Information
                    </h5>
                </div>

                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td width="40%"><strong><i class="bi bi-person"></i> Name:</strong></td>
                            <td>@Model.OrderHeader.Name</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-telephone"></i> Phone:</strong></td>
                            <td>@Model.OrderHeader.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-house-door"></i> Address:</strong></td>
                            <td>@Model.OrderHeader.StreetAddress</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-building"></i> City/State:</strong></td>
                            <td>@Model.OrderHeader.City@(!string.IsNullOrEmpty(Model.OrderHeader.State) ? $", {Model.OrderHeader.State}" : "")</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-mailbox"></i> Postal Code:</strong></td>
                            <td>@Model.OrderHeader.PostalCode</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-globe"></i> Country:</strong></td>
                            <td>@Model.OrderHeader.Country</td>
                        </tr>
                    </table>

                    <a asp-action="Checkout" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="bi bi-pencil"></i> Edit Shipping Info
                    </a>
                </div>
            </div>

            <!-- Payment Method Summary -->
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-credit-card"></i> Payment Method
                    </h5>
                </div>
                <div class="card-body">
                    @if (User.IsInRole(SD.Role_Company))
                    {
                        if (companyInactive)
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                Your company account is inactive. Payment must be completed immediately.
                            </div>

                            <div class="d-flex">
                                <i class="bi bi-credit-card text-success fs-4 me-3"></i>
                                <div>
                                    <h6>Credit Card / Debit Card</h6>
                                    <p class="text-muted small mb-0">
                                        Payment is required before shipment approval.
                                    </p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" value="true" id="payNowSwitch">
                                <label class="form-check-label" for="payNowSwitch">
                                    Pay now instead of deferred (optional)
                                </label>
                            </div>

                            <div class="alert alert-success mt-2">
                                Payment is normally deferred and due within 30 days.
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- QR Code Preview Card -->
            <div class="card border-0 shadow-sm mt-3 bg-light">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-qr-code text-primary me-2"></i>Track Your Order After Purchase
                    </h6>
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <img src="data:image/png;base64,@placeholderQrCodeBase64"
                                 alt="Sample QR Code"
                                 style="width: 60px; height: 60px;"
                                 class="img-thumbnail" />
                        </div>
                        <div class="col">
                            <p class="small text-muted mb-0">
                                <i class="bi bi-phone"></i> Scan with your phone<br />
                                <i class="bi bi-geo-alt"></i> Track order status anytime
                            </p>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div class="d-flex justify-content-between">
                        <div class="text-center">
                            <i class="bi bi-envelope-check text-success fs-5"></i>
                            <p class="small mb-0">Email Receipt</p>
                        </div>
                        <div class="text-center">
                            <i class="bi bi-qr-code text-primary fs-5"></i>
                            <p class="small mb-0">QR Code</p>
                        </div>
                        <div class="text-center">
                            <i class="bi bi-sms text-info fs-5"></i>
                            <p class="small mb-0">SMS Updates</p>
                        </div>
                        <div class="text-center">
                            <i class="bi bi-truck text-warning fs-5"></i>
                            <p class="small mb-0">Real-time Tracking</p>
                        </div>
                    </div>
                    <div class="alert alert-light small mt-3 mb-0">
                        <i class="bi bi-clock-history"></i>
                        QR code and tracking link will be sent once your order is approved for shipment.
                    </div>
                </div>
            </div>
        </div>

        <!-- ORDER SUMMARY -->
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-cart-check"></i> Order Summary
                        <span class="badge bg-light text-dark float-end">@Model.ShoppingCartList.Count items</span>
                    </h5>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ShoppingCartList)
                                {
                                    var subtotal = item.ProductVariant.Price * item.Count;
                                    <tr>
                                        <td>
                                            <strong>@item.ProductVariant.Product.Name</strong>
                                            <br />
                                            <div class="d-flex align-items-center mt-1">
                                                <span class="badge me-1"
                                                      style="background-color: @GetColorCode(item.ProductVariant.Color);
                                                    color: @GetTextColor(item.ProductVariant.Color);">
                                                    <i class="bi bi-droplet"></i> @item.ProductVariant.Color
                                                </span>
                                                @if (item.ProductVariant.SizeValue != null)
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="bi bi-rulers"></i> @item.ProductVariant.SizeValue.DisplayText
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="bi bi-dash"></i> No Size
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-center align-middle">@item.Count</td>
                                        <td class="text-end align-middle">@subtotal.ToString("C", culture)</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                @{
                                    var confirmDiscount = ViewBag.PromotionDiscount as Models.Interfaces.PromotionDiscount;
                                    var confirmSubtotal = ViewBag.Subtotal as decimal? ?? Model.OrderTotal;
                                }
                                <tr>
                                    <td colspan="2" class="text-end"><strong>Subtotal:</strong></td>
                                    <td class="text-end">@confirmSubtotal.ToString("C", culture)</td>
                                </tr>
                                @if (confirmDiscount != null && confirmDiscount.TotalDiscount > 0)
                                {
                                    @foreach (var applied in confirmDiscount.AppliedPromotions)
                                    {
                                        <tr class="table-success">
                                            <td colspan="2" class="text-end">
                                                <i class="bi bi-gift text-success"></i>
                                                <strong class="text-success">@applied.DisplayText</strong>
                                                <small class="text-muted">(@applied.CategoryName)</small>
                                            </td>
                                            <td class="text-end text-success fw-bold">-@applied.Discount.ToString("C", culture)</td>
                                        </tr>
                                    }
                                }
                                <tr>
                                    <td colspan="2" class="text-end"><strong>Shipping:</strong></td>
                                    <td class="text-end">Free</td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="text-end"><strong>Total:</strong></td>
                                    <td class="text-end">
                                        <h5 class="text-primary mb-0">@Model.OrderTotal.ToString("C", culture)</h5>
                                        @if (confirmDiscount != null && confirmDiscount.TotalDiscount > 0)
                                        {
                                            <small class="text-success"><i class="bi bi-check-circle"></i> You save @confirmDiscount.TotalDiscount.ToString("C", culture)!</small>
                                        }
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <!-- PLACE ORDER FORM -->
                    <form asp-action="PlaceOrder" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="OrderHeader.ApplicationUserId" />
                        <input type="hidden" asp-for="OrderHeader.Name" />
                        <input type="hidden" asp-for="OrderHeader.PhoneNumber" />
                        <input type="hidden" asp-for="OrderHeader.StreetAddress" />
                        <input type="hidden" asp-for="OrderHeader.City" />
                        <input type="hidden" asp-for="OrderHeader.State" />
                        <input type="hidden" asp-for="OrderHeader.PostalCode" />
                        <input type="hidden" asp-for="OrderHeader.Country" />
                        <input type="hidden" asp-for="OrderTotal" />

                        <!-- Pay Now Checkbox for Company Users -->
                        @if (User.IsInRole(SD.Role_Company))
                        {
                            <input type="hidden" id="payNowHidden" name="payNow" value="false" />
                            <script>
                                                        document.getElementById('payNowSwitch').addEventListener('change', function () {
                                                            document.getElementById('payNowHidden').value = this.checked ? 'true' : 'false';
                                                        });
                            </script>
                        }

                        <button type="submit" class="btn btn-success w-100 mt-3 py-3">
                            <i class="bi @(User.IsInRole(SD.Role_Company) ? "bi-building" : "bi-credit-card")"></i>
                            @(User.IsInRole(SD.Role_Company) ? "Place Order" : "Confirm & Pay")
                        </button>
                    </form>

                    <p class="text-muted small text-center mt-3">
                        <i class="bi bi-shield-lock"></i>
                        Your information is secure and encrypted
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }

    public string GetTextColor(string color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}