@model OrderHeader
@using System.Globalization
@using MyUtility
@using Models
@using Models.Interfaces
@inject IQrCodeService QrCodeService

@{
    ViewData["Title"] = $"Order Receipt #{Model.Id}";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    var estimatedDeliveryStart = DateTime.Now.AddDays(3).ToString("dd MMM yyyy");
    var estimatedDeliveryEnd = DateTime.Now.AddDays(5).ToString("dd MMM yyyy");
    
    // ✅ Generate QR Code image (still uses the service)
    var qrCodeBase64 = QrCodeService.GenerateOrderQrCode(Model.Id);
    
    // ✅ Generate tracking URL using Url.Action (same as Details page)
    var trackingUrl = Url.Action("Track", "Order", new { id = Model.Id, area = "Customer" });
    
    // Get progress percentage
    var progressPercentage = SD.GetOrderProgressPercentage(Model.OrderStatus);
    var trackingMessage = SD.GetOrderTrackingMessage(Model.OrderStatus);
    var progressBarColor = SD.GetStatusProgressBarColor(Model.OrderStatus);
}

<div class="container mt-4 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Order" asp-action="History">Orders</a></li>
            <li class="breadcrumb-item active" aria-current="page">Receipt #@Model.Id</li>
        </ol>
    </nav>

    <!-- Success Message -->
    <div class="alert alert-success text-center py-4 mb-4 shadow-sm">
        <i class="bi bi-check-circle-fill display-4 d-block mb-3 text-success"></i>
        <h3 class="fw-bold">Thank you for your order!</h3>
        <p class="lead mb-0">Order #@Model.Id has been placed successfully.</p>
        <p class="small text-muted mt-2">
            <i class="bi bi-envelope"></i> A confirmation email has been sent to your email address.
        </p>
    </div>

    <!-- QR Code & Quick Actions Row -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-qr-code text-primary me-2"></i>Track Your Order
                    </h5>
                    @if (!string.IsNullOrEmpty(qrCodeBase64))
                    {
                        <div class="qr-code-container mb-3">
                            <img src="data:image/png;base64,@qrCodeBase64"
                                 alt="Order Tracking QR Code"
                                 style="width: 150px; height: 150px; cursor: pointer;"
                                 onclick="window.open('@trackingUrl', '_blank')"
                                 class="img-thumbnail qr-code" />
                            <p class="text-muted small mt-2 mb-0">
                                <i class="bi bi-phone"></i> Scan with your phone
                            </p>
                        </div>
                        <a href="@trackingUrl" class="btn btn-primary btn-sm w-100" target="_blank">
                            <i class="bi bi-geo-alt"></i> Track Order Now
                        </a>
                    }
                    else
                    {
                        <div class="text-muted py-3">
                            <i class="bi bi-qr-code-scan fs-1"></i>
                            <p class="mt-2 mb-0">QR code will be available after payment</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center h-100">
                        <div class="col-md-8">
                            <h6 class="fw-bold text-primary mb-2">
                                <i class="bi bi-info-circle"></i> Order Status
                            </h6>
                            <p class="mb-2">@trackingMessage</p>
                            <div class="progress mb-2" style="height: 8px;">
                                <div class="progress-bar @progressBarColor progress-bar-striped"
                                     style="width: @progressPercentage%"></div>
                            </div>
                            <small class="text-muted">@progressPercentage% complete</small>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <a href="@trackingUrl" class="btn btn-outline-primary w-100" target="_blank">
                                <i class="bi bi-truck"></i> View Tracking Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Status Bar -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-3">
                    <div class="p-3">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex p-3 mb-2">
                            <i class="bi bi-check-circle-fill text-success fs-2"></i>
                        </div>
                        <h6 class="fw-bold">Order Placed</h6>
                        <small class="text-muted">@Model.OrderDate.ToString("dd MMM yyyy")</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3">
                        <div class="rounded-circle @(Model.PaymentDate.HasValue ? "bg-success" : "bg-warning") bg-opacity-10 d-inline-flex p-3 mb-2">
                            <i class="bi @(Model.PaymentDate.HasValue ? "bi-check-circle-fill text-success" : "bi-hourglass-split text-warning") fs-2"></i>
                        </div>
                        <h6 class="fw-bold">Payment</h6>
                        <small class="text-muted">@(Model.PaymentDate?.ToString("dd MMM yyyy") ?? "Pending")</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3">
                        <div class="rounded-circle @(Model.ShippedDate.HasValue ? "bg-success" : "bg-secondary") bg-opacity-10 d-inline-flex p-3 mb-2">
                            <i class="bi @(Model.ShippedDate.HasValue ? "bi-check-circle-fill text-success" : "bi-clock text-secondary") fs-2"></i>
                        </div>
                        <h6 class="fw-bold">Shipped</h6>
                        <small class="text-muted">@(Model.ShippedDate?.ToString("dd MMM yyyy") ?? "Pending")</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3">
                        <div class="rounded-circle @(Model.DeliveredDate.HasValue ? "bg-success" : "bg-primary") bg-opacity-10 d-inline-flex p-3 mb-2">
                            <i class="bi @(Model.DeliveredDate.HasValue ? "bi-check-circle-fill text-success" : "bi-truck text-primary") fs-2"></i>
                        </div>
                        <h6 class="fw-bold">Delivered</h6>
                        <small class="text-muted">@(Model.DeliveredDate?.ToString("dd MMM yyyy") ?? "Est. @estimatedDeliveryStart")</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- SHIPPING INFORMATION -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-truck"></i> Shipping Information
                    </h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td width="40%"><strong><i class="bi bi-person me-2"></i>Name:</strong></td>
                            <td>@Model.Name</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-telephone me-2"></i>Phone:</strong></td>
                            <td>@Model.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-house-door me-2"></i>Address:</strong></td>
                            <td>@Model.StreetAddress</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-building me-2"></i>City/State:</strong></td>
                            <td>@Model.City, @Model.State</td>
                        </tr>
                        <tr>
                            <td><strong><i class="bi bi-mailbox me-2"></i>Postal Code:</strong></td>
                            <td>@Model.PostalCode</td>
                        </tr>
                    </table>
                    
                    @if (!string.IsNullOrEmpty(Model.TrackingNumber))
                    {
                        <div class="alert alert-info mt-3 mb-0">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-box fs-4 me-3"></i>
                                <div>
                                    <strong>Tracking Number:</strong> @Model.TrackingNumber<br />
                                    @if (!string.IsNullOrEmpty(Model.Carrier))
                                    {
                                        <small>Carrier: @Model.Carrier</small>
                                        var carrierUrl = SD.GetTrackingUrl(Model.Carrier, Model.TrackingNumber);
                                        if (carrierUrl != "#")
                                        {
                                            <br />
                                            <a href="@carrierUrl" target="_blank" class="btn btn-sm btn-link p-0">
                                                <i class="bi bi-box-arrow-up-right"></i> Track with carrier
                                            </a>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- PAYMENT INFORMATION -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-credit-card"></i> Payment Information
                    </h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td width="40%"><strong>Order ID:</strong></td>
                            <td><span class="badge bg-dark">#@Model.Id</span></td>
                        </tr>
                        <tr>
                            <td><strong>Order Date:</strong></td>
                            <td>@Model.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                        <tr>
                            <td><strong>Payment Status:</strong></td>
                            <td>
                                <span class="badge @SD.GetPaymentStatusBadgeClass(Model.PaymentStatus) px-3 py-2">
                                    <i class="bi @SD.GetPaymentStatusIcon(Model.PaymentStatus) me-1"></i>
                                    @Model.PaymentStatus
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Order Status:</strong></td>
                            <td>
                                <span class="badge @SD.GetOrderStatusBadgeClass(Model.OrderStatus) px-3 py-2">
                                    <i class="bi @SD.GetOrderStatusIcon(Model.OrderStatus) me-1"></i>
                                    @Model.OrderStatus
                                </span>
                            </td>
                        </tr>
                        @if (Model.PaymentDueDate.HasValue)
                        {
                            <tr>
                                <td><strong>Payment Due:</strong></td>
                                <td>@Model.PaymentDueDate.Value.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                        @if (Model.PaymentDate.HasValue)
                        {
                            <tr>
                                <td><strong>Payment Date:</strong></td>
                                <td>@Model.PaymentDate.Value.ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                        }
                    </table>
                    
                    <div class="mt-3 p-3 bg-light rounded">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold">Total Amount:</span>
                            <span class="h5 text-primary mb-0">@Model.OrderTotal.ToString("C", culture)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ORDER DETAILS -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-info text-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-receipt"></i> Order Details
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width: 40%" class="py-3">Product</th>
                            <th style="width: 15%" class="py-3">Price</th>
                            <th style="width: 10%" class="py-3">Quantity</th>
                            <th style="width: 15%" class="py-3">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            var subtotal = item.Price * item.Count;
                            <tr>
                                <td class="py-3">
                                    <div class="d-flex flex-column">
                                        <strong class="fs-6">@item.ProductVariant?.Product?.Name</strong>
                                        <div class="d-flex align-items-center mt-2 flex-wrap gap-2">
                                            <!-- Color Badge -->
                                            <span class="badge"
                                                  style="background-color: @GetColorCode(item.ProductVariant?.Color);
                                                color: @GetTextColor(item.ProductVariant?.Color);
                                                padding: 0.5rem 1rem;">
                                                <i class="bi bi-droplet me-1"></i> @item.ProductVariant?.Color
                                            </span>
                                            
                                            <!-- Size Badge -->
                                            @if (item.ProductVariant?.SizeValue != null)
                                            {
                                                <span class="badge bg-secondary" style="padding: 0.5rem 1rem;">
                                                    <i class="bi bi-rulers me-1"></i> @item.ProductVariant.SizeValue.DisplayText
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary" style="padding: 0.5rem 1rem;">
                                                    <i class="bi bi-dash me-1"></i> No Size
                                                </span>
                                            }
                                        </div>
                                        @if (item.ProductVariant?.SizeValue?.Description != null)
                                        {
                                            <small class="text-muted mt-2">
                                                <i class="bi bi-info-circle me-1"></i> @item.ProductVariant.SizeValue.Description
                                            </small>
                                        }
                                    </div>
                                </td>
                                <td class="text-center align-middle py-3">
                                    <span class="fw-bold">@item.Price.ToString("C", culture)</span>
                                </td>
                                <td class="text-center align-middle py-3">
                                    <span class="badge bg-secondary rounded-pill px-3 py-2">@item.Count</span>
                                </td>
                                <td class="text-end align-middle py-3">
                                    <span class="fw-bold text-primary fs-5">@subtotal.ToString("C", culture)</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end py-3"><strong class="fs-5">Subtotal:</strong></td>
                            <td class="text-end py-3"><strong class="fs-5">@Model.OrderDetails.Sum(d => d.Price * d.Count).ToString("C", culture)</strong></td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end py-2"><strong>Shipping:</strong></td>
                            <td class="text-end py-2"><span class="text-success">Free</span></td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end py-3"><strong class="fs-4">Total:</strong></td>
                            <td class="text-end py-3">
                                <h4 class="text-primary mb-0 fw-bold">@Model.OrderTotal.ToString("C", culture)</h4>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-5 gap-3">
        <a asp-action="History" asp-controller="Order" asp-area="Customer" class="btn btn-outline-primary btn-lg px-4 w-100 w-md-auto">
            <i class="bi bi-clock-history me-2"></i> View Order History
        </a>
        
        <a href="@trackingUrl" target="_blank" class="btn btn-info btn-lg px-4 w-100 w-md-auto">
            <i class="bi bi-geo-alt me-2"></i> Track Order
        </a>
        
        <a asp-action="Index" asp-controller="Home" asp-area="Customer" class="btn btn-primary btn-lg px-4 w-100 w-md-auto">
            <i class="bi bi-arrow-left me-2"></i> Continue Shopping
        </a>
    </div>
    
    <!-- Share & Help Section -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card border-0 bg-light">
                <div class="card-body text-center">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-share"></i> Share Your Order
                    </h6>
                    <div class="d-flex justify-content-center gap-3">
                        <button class="btn btn-outline-secondary" onclick="copyToClipboard('@trackingUrl')">
                            <i class="bi bi-link"></i> Copy Tracking Link
                        </button>
                        <a href="mailto:?subject=Track my order #@Model.Id&body=Track your order here: @trackingUrl"
                               class="btn btn-outline-secondary">
                            <i class="bi bi-envelope"></i> Email
                        </a>
                        <button class="btn btn-outline-secondary" onclick="window.print()">
                            <i class="bi bi-printer"></i> Print
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 bg-light">
                <div class="card-body text-center">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-question-circle"></i> Need Help?
                    </h6>
                    <p class="text-muted small mb-0">
                        Have questions about your order?
                        <a href="#" class="text-decoration-none">Contact Customer Support</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Receipt page loaded for order #@Model.Id');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                alert('Tracking link copied to clipboard!');
            }).catch(function() {
                alert('Failed to copy link');
            });
        }
    </script>
}

@functions {
    public string GetColorCode(string? color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string? color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}