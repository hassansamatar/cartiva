@model CheckoutVM
@using System.Globalization
@using ApplicationUtility
@using Models.Interfaces
@inject IQrCodeService QrCodeService

@{
    ViewData["Title"] = "Checkout";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
   
    // Placeholder QR code (the real QR code will be generated after payment)
    var placeholderOrderId = 99999;
    var placeholderQrCodeBase64 = QrCodeService.GenerateOrderQrCode(placeholderOrderId);
    var placeholderTrackingUrl = Url.Action("Track", "Order", new { id = placeholderOrderId, area = "Customer" });
}

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Cart" asp-action="Index">Cart</a></li>
            <li class="breadcrumb-item active" aria-current="page">Checkout</li>
        </ol>
    </nav>

    <h2 class="mb-4">
        <i class="bi bi-credit-card"></i> Checkout
    </h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- CUSTOMER / SHIPPING INFO -->
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-truck"></i> Shipping Details
                    </h5>
                </div>

                <div class="card-body">
                    <form asp-controller="Order"   asp-action="ConfirmOrder" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <input asp-for="OrderHeader.ApplicationUserId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="OrderHeader.Name" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-person"></i>
                                </span>
                                <input asp-for="OrderHeader.Name" class="form-control" placeholder="Full name" />
                            </div>
                            <span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="OrderHeader.PhoneNumber" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-telephone"></i>
                                </span>
                                <input asp-for="OrderHeader.PhoneNumber" class="form-control" type="tel" placeholder="+47 12345678" />
                            </div>
                            <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="OrderHeader.StreetAddress" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-house-door"></i>
                                </span>
                                <input asp-for="OrderHeader.StreetAddress" class="form-control" placeholder="Street address" />
                            </div>
                            <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="OrderHeader.City" class="form-label fw-bold"></label>
                                <input asp-for="OrderHeader.City" class="form-control" placeholder="City" />
                                <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="OrderHeader.State" class="form-label fw-bold"></label>
                                <input asp-for="OrderHeader.State" class="form-control" placeholder="State / Region" />
                                <span asp-validation-for="OrderHeader.State" class="text-danger"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="OrderHeader.PostalCode" class="form-label fw-bold"></label>
                                <input asp-for="OrderHeader.PostalCode" class="form-control" placeholder="Postal code" />
                                <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Country field -->
                        <div class="mb-3">
                            <label asp-for="OrderHeader.Country" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-globe"></i>
                                </span>
                                <input asp-for="OrderHeader.Country" class="form-control" placeholder="Country" value="Norway" />
                            </div>
                            <span asp-validation-for="OrderHeader.Country" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-check-circle"></i> Review Order
                        </button>
                    </form>
                </div>
            </div>

            <!-- QR Code Preview Card -->
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-qr-code text-primary me-2"></i>Track Your Order After Purchase
                    </h6>
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <img src="data:image/png;base64,@placeholderQrCodeBase64"
                                 alt="Sample QR Code"
                                 style="width: 60px; height: 60px;"
                                 class="img-thumbnail" />
                        </div>
                        <div class="col">
                            <p class="small text-muted mb-0">
                                <i class="bi bi-phone"></i> Scan with your phone<br />
                                <i class="bi bi-geo-alt"></i> Track order status anytime
                            </p>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div class="d-flex justify-content-between">
                        <div class="text-center">
                            <i class="bi bi-envelope-check text-success fs-5"></i>
                            <p class="small mb-0">Email Receipt</p>
                        </div>
                        <div class="text-center">
                            <i class="bi bi-qr-code text-primary fs-5"></i>
                            <p class="small mb-0">QR Code</p>
                        </div>
                        <div class="text-center">
                            <i class="bi bi-sms text-info fs-5"></i>
                            <p class="small mb-0">SMS Updates</p>
                        </div>
                        <div class="text-center">
                            <i class="bi bi-truck text-warning fs-5"></i>
                            <p class="small mb-0">Real-time Tracking</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- New: After-payment info (shipment approval) -->
            <div class="card border-0 shadow-sm mt-3 bg-primary bg-opacity-10">
                <div class="card-body">
                    <h6 class="fw-bold mb-2">
                        <i class="bi bi-check2-circle text-primary"></i> After Payment
                    </h6>
                    <p class="small text-muted mb-2">
                        Once your payment is confirmed, an admin will review and approve the shipment. You will receive an email with the final tracking number and QR code.
                    </p>
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-clock-history"></i>
                        <span class="small">Shipment approval usually within 1 business day.</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ORDER SUMMARY -->
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-cart"></i> Order Summary
                        <span class="badge bg-light text-dark float-end">@Model.ShoppingCartList.Count items</span>
                    </h5>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                32
                                <th>Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ShoppingCartList)
                            {
                                var subtotal = item.ProductVariant.Price * item.Count;

                                <tr>
                                    <td>
                                        <strong>@item.ProductVariant.Product.Name</strong>
                                        <br />
                                        <div class="d-flex align-items-center mt-1">
                                            <!-- Color Badge -->
                                            <span class="badge me-1"
                                                  style="background-color: @GetColorCode(item.ProductVariant.Color);
                                                color: @GetTextColor(item.ProductVariant.Color);">
                                                <i class="bi bi-droplet"></i> @item.ProductVariant.Color
                                            </span>

                                            <!-- Size Badge -->
                                            @if (item.ProductVariant.SizeValue != null)
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-rulers"></i> @item.ProductVariant.SizeValue.DisplayText
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-dash"></i> No Size
                                                </span>
                                            }
                                        </div>
                                        @if (item.ProductVariant.SizeValue?.Description != null)
                                        {
                                            <small class="text-muted d-block mt-1">
                                                @item.ProductVariant.SizeValue.Description
                                            </small>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="fw-bold">@item.Count</span>
                                    </td>
                                    <td class="text-end align-middle">
                                        <strong class="text-primary">@subtotal.ToString("C", culture)</strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="2" class="text-end"><strong>Subtotal:</strong></td>
                                <td class="text-end">@Model.OrderTotal.ToString("C", culture)</td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-end"><strong>Shipping:</strong></td>
                                <td class="text-end">Free</td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-end"><strong>Total:</strong></td>
                                <td class="text-end">
                                    <h5 class="text-primary mb-0">@Model.OrderTotal.ToString("C", culture)</h5>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Estimated Delivery (using SD helper) -->
                <div class="alert alert-info mt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-calendar-check fs-4 me-2"></i>
                            <strong>Estimated Delivery:</strong>
                        </div>
                        <div>
                            @{
                                var start = DateTime.Now.AddDays(3);
                                var end = DateTime.Now.AddDays(5);
                            }
                            <span class="fw-bold">@start.ToString("dd MMM")</span> -
                            <span class="fw-bold">@end.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                    <p class="small text-muted mt-2 mb-0">
                        <i class="bi bi-truck"></i> @SD.GetDeliveryEstimate(SD.DeliveryStandard)
                    </p>
                </div>

                <!-- Payment Method Info -->
                <div class="alert alert-success mt-3">
                    <div class="d-flex">
                        <div class="me-3">
                            <i class="bi bi-shield-check fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">Secure Checkout</h6>
                            <p class="small text-muted mb-0">
                                Your payment information is secure. We'll ask for payment details after order review.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- What You'll Get Card -->
                <div class="card mt-3 border-0 bg-light">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-2">
                            <i class="bi bi-gift"></i> What You'll Get
                        </h6>
                        <div class="row">
                            <div class="col-6">
                                <ul class="list-unstyled small mb-0">
                                    <li><i class="bi bi-envelope-check text-success me-2"></i> Order confirmation email</li>
                                    <li><i class="bi bi-receipt text-primary me-2"></i> Digital receipt with QR code</li>
                                </ul>
                            </div>
                            <div class="col-6">
                                <ul class="list-unstyled small mb-0">
                                    <li><i class="bi bi-sms text-info me-2"></i> SMS shipping updates</li>
                                    <li><i class="bi bi-geo-alt text-warning me-2"></i> Real-time tracking link</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" />

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }

    public string GetTextColor(string color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}