@model OrderHeader
@using System.Globalization

@{
    ViewData["Title"] = "Order Confirmation";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="container mt-5">
    <div class="alert alert-success text-center">
        <i class="bi bi-check-circle-fill display-4 d-block mb-3 text-success"></i>
        <h2 class="fw-bold">Thank you for your order!</h2>
        <p class="lead">Your payment has been received.</p>
        <p>Order #@Model.Id has been placed successfully.</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> Order Status: Awaiting Shipment Approval</h5>
        </div>
        <div class="card-body">
            <p>Your order is now being processed. An administrator will review and approve the shipment shortly.</p>
            <p>You will receive an email with the tracking number and QR code once the shipment is approved.</p>
            <p>This typically takes 1 business day.</p>
            <hr />
            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="History" class="btn btn-outline-primary">View Order History</a>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">View Order Details</a>
            </div>
        </div>
    </div>

    <div class="text-center mt-4">
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Continue Shopping</a>
    </div>
</div>