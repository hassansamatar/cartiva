@model CheckoutVM
@using System.Globalization
@using MyUtility

@{
    ViewData["Title"] = "Confirm Order";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="container mt-4">

    <h2 class="mb-4">Confirm Your Order</h2>

    <div class="row">

        <!-- SHIPPING INFO -->
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header"><h5>Shipping Information</h5></div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.OrderHeader.Name</p>
                    <p><strong>Phone:</strong> @Model.OrderHeader.PhoneNumber</p>
                    <p><strong>Address:</strong> @Model.OrderHeader.StreetAddress</p>
                    <p><strong>City / State:</strong> @Model.OrderHeader.City, @Model.OrderHeader.State</p>
                    <p><strong>Postal Code:</strong> @Model.OrderHeader.PostalCode</p>

                    <a asp-action="Checkout" class="btn btn-secondary mt-3 w-100">
                        Edit Shipping Info
                    </a>
                </div>
            </div>
        </div>

        <!-- ORDER SUMMARY -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header"><h5>Order Summary</h5></div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ShoppingCartList)
                            {
                                var subtotal = item.ProductVariant.Price * item.Count;
                                <tr>
                                    <td>
                                        @item.ProductVariant.Product.Name
                                        <br />
                                        <small>@item.ProductVariant.Color / @item.ProductVariant.Size</small>
                                    </td>
                                    <td>@item.Count</td>
                                    <td>@subtotal.ToString("C", culture)</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <hr />
                    <h5 class="text-end">
                        Total: <strong>@Model.OrderTotal.ToString("C", culture)</strong>
                    </h5>

                    @if (User.IsInRole(SD.Role_Company))
                    {
                        <p class="text-success mt-2">
                            No payment is required now. Payment is due within 30 days from order date.
                        </p>
                    }
                    else
                    {
                        <p class="text-warning mt-2">
                            Payment is required immediately after placing this order.
                        </p>
                    }

                    <form asp-action="PlaceOrder" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success w-100 mt-3">
                            @(User.IsInRole(SD.Role_Company) ? "Place Order" : "Confirm & Pay")
                        </button>
                    </form>

                </div>
            </div>
        </div>

    </div>

</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}