@model IEnumerable<OrderHeader>
@using System.Globalization
@using MyUtility
@{
    ViewData["Title"] = "My Order History";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="container mt-4 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">My Orders</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="text-primary">
                <i class="bi bi-clock-history"></i> My Order History
            </h2>
            <p class="text-muted">View and track all your orders</p>
        </div>
        <div class="mt-3 mt-md-0">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> Continue Shopping
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- Empty State -->
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-box-seam" style="font-size: 5rem; color: #dee2e6;"></i>
            </div>
            <h3 class="text-muted mb-3">No orders yet</h3>
            <p class="lead mb-4">Looks like you haven't placed any orders with us yet.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="bi bi-shop"></i> Start Shopping
            </a>
        </div>
    }
    else
    {
        <!-- Stats Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Total Orders</h6>
                                <h3 class="mt-2 mb-0">@Model.Count()</h3>
                            </div>
                            <i class="bi bi-bag fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Delivered</h6>
                                <h3 class="mt-2 mb-0">@Model.Count(o => o.OrderStatus == SD.StatusDelivered)</h3>
                            </div>
                            <i class="bi bi-check-circle fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Processing</h6>
                                <h3 class="mt-2 mb-0">@Model.Count(o => o.OrderStatus == SD.StatusProcessing || o.OrderStatus == SD.StatusShipped)</h3>
                            </div>
                            <i class="bi bi-gear fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Total Spent</h6>
                                <h3 class="mt-2 mb-0">@Model.Sum(o => o.OrderTotal).ToString("C", culture)</h3>
                            </div>
                            <i class="bi bi-currency-exchange fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter / Search Bar (Optional) -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <select class="form-select" id="statusFilter">
                            <option value="">All Orders</option>
                            <option value="@SD.StatusPending">Pending</option>
                            <option value="@SD.StatusProcessing">Processing</option>
                            <option value="@SD.StatusShipped">Shipped</option>
                            <option value="@SD.StatusOutForDelivery">Out for Delivery</option>
                            <option value="@SD.StatusDelivered">Delivered</option>
                            <option value="@SD.StatusCancelled">Cancelled</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input type="text" class="form-control" id="searchOrders" placeholder="Search by order # or product...">
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" id="dateFilter">
                            <option value="">All Time</option>
                            <option value="30">Last 30 Days</option>
                            <option value="90">Last 3 Months</option>
                            <option value="365">Last Year</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders List -->
        <div class="row g-4">
            @foreach (var order in Model.OrderByDescending(o => o.OrderDate))
            {
                <div class="col-12">
                    <div class="card shadow-sm hover-shadow">
                        <!-- Order Header -->
                        <div class="card-header bg-light py-3">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                <div class="d-flex align-items-center mb-2 mb-md-0">
                                    <i class="bi bi-receipt fs-4 me-2 text-primary"></i>
                                    <div>
                                        <h5 class="mb-0">Order #@order.Id</h5>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i> @order.OrderDate.ToString("dd MMM yyyy 'at' HH:mm")
                                        </small>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge @SD.GetOrderStatusBadgeClass(order.OrderStatus) px-3 py-2">
                                        <i class="bi @SD.GetOrderStatusIcon(order.OrderStatus) me-1"></i>
                                        @order.OrderStatus
                                    </span>
                                    <span class="badge @SD.GetPaymentStatusBadgeClass(order.PaymentStatus) px-3 py-2">
                                        <i class="bi bi-credit-card me-1"></i>
                                        @order.PaymentStatus
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Order Body -->
                        <div class="card-body">
                            <div class="row">
                                <!-- Order Items Preview -->
                                <div class="col-md-7">
                                    <h6 class="fw-bold mb-3">Items (@order.OrderDetails?.Count() ?? 0)</h6>
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var item in order.OrderDetails.Take(2))
                                        {
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.ProductVariant?.Product?.ImageUrl))
                                                {
                                                    <img src="@item.ProductVariant.Product.ImageUrl"
                                                         alt="@item.ProductVariant.Product.Name"
                                                         class="rounded me-2"
                                                         style="width: 40px; height: 40px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-light rounded me-2 d-flex align-items-center justify-content-center"
                                                         style="width: 40px; height: 40px;">
                                                        <i class="bi bi-image text-muted small"></i>
                                                    </div>
                                                }
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between">
                                                        <span class="fw-bold">@item.ProductVariant?.Product?.Name</span>
                                                        <span class="text-muted">x@item.Count</span>
                                                    </div>
                                                    <div class="d-flex gap-2 small">
                                                        <span class="badge" style="background-color: @GetColorCode(item.ProductVariant?.Color); color: @GetTextColor(item.ProductVariant?.Color);">
                                                            @item.ProductVariant?.Color
                                                        </span>
                                                        @if (item.ProductVariant?.SizeValue != null)
                                                        {
                                                            <span class="badge bg-secondary">
                                                                @item.ProductVariant.SizeValue.DisplayText
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        @if (order.OrderDetails?.Count() > 2)
                                        {
                                            <div class="text-muted small">
                                                <i class="bi bi-plus-circle"></i> @(order.OrderDetails.Count() - 2) more items
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- Order Summary -->
                                <div class="col-md-5 mt-3 mt-md-0">
                                    <div class="bg-light p-3 rounded">
                                        <h6 class="fw-bold mb-3">Order Summary</h6>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="text-muted">Subtotal:</span>
                                            <span>@order.OrderDetails.Sum(d => d.Price * d.Count).ToString("C", culture)</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="text-muted">Shipping:</span>
                                            <span class="text-success">Free</span>
                                        </div>
                                        <hr class="my-2">
                                        <div class="d-flex justify-content-between fw-bold">
                                            <span>Total:</span>
                                            <span class="text-primary h5 mb-0">@order.OrderTotal.ToString("C", culture)</span>
                                        </div>
                                        
                                        @if (!string.IsNullOrEmpty(order.TrackingNumber))
                                        {
                                            <div class="mt-3 pt-2 border-top">
                                                <small class="text-muted d-block">
                                                    <i class="bi bi-box"></i> Tracking: @order.TrackingNumber
                                                </small>
                                                <small class="text-muted">
                                                    <i class="bi bi-truck"></i> Carrier: @order.Carrier
                                                </small>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Order Footer -->
                        <div class="card-footer bg-white py-3">
                            <div class="d-flex flex-wrap justify-content-between align-items-center">
                                <div class="mb-2 mb-sm-0">
                                    <span class="text-muted me-3">
                                        <i class="bi bi-credit-card"></i> @order.PaymentStatus
                                    </span>
                                    @if (order.ShippingDate.HasValue)
                                    {
                                        <span class="text-muted">
                                            <i class="bi bi-truck"></i> Shipped: @order.ShippingDate.Value.ToString("dd MMM yyyy")
                                        </span>
                                    }
                                </div>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View Details
                                    </a>
                                    @if (order.OrderStatus == SD.StatusDelivered)
                                    {
                                        <a href="#" class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-star"></i> Review
                                        </a>
                                    }
                                    @if (order.OrderStatus == SD.StatusShipped || order.OrderStatus == SD.StatusOutForDelivery)
                                    {
                                        <a href="@SD.GetTrackingUrl(order.Carrier, order.TrackingNumber)" target="_blank" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-truck"></i> Track
                                        </a>
                                    }
                                    @if (order.OrderStatus == SD.StatusPending)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" onclick="cancelOrder(@order.Id)">
                                            <i class="bi bi-x-circle"></i> Cancel
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Filter functionality
            $('#statusFilter, #dateFilter, #searchOrders').on('change keyup', function() {
                filterOrders();
            });
        });

        function filterOrders() {
            // Implement filter logic here
            console.log('Filtering orders...');
        }

        function cancelOrder(orderId) {
            if (confirm('Are you sure you want to cancel this order?')) {
                $.post('@Url.Action("CancelOrder", "Order")', { id: orderId })
                    .done(function() {
                        location.reload();
                    });
            }
        }
    </script>
}

@functions {
    public string GetColorCode(string? color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string? color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}
