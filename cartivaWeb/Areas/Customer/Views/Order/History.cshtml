@model IEnumerable<OrderHeader>
@using System.Globalization
@using ApplicationUtility
@using Models.Interfaces
@inject IQrCodeService QrCodeService

@{
    ViewData["Title"] = "My Order History";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">My Orders</li>
        </ol>
    </nav>

    <h2 class="text-primary mb-4"><i class="bi bi-clock-history"></i> My Order History</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-box-seam" style="font-size: 5rem; color: #dee2e6;"></i>
            <h3 class="text-muted mb-3">No orders yet</h3>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="bi bi-shop"></i> Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model.OrderByDescending(o => o.OrderDate))
            {
                var trackingUrl = Url.Action("Track", "Order", new { id = order.Id, area = "Customer" });
                var qrCodeBase64 = QrCodeService.GenerateOrderQrCode(order.Id);
                var progressPercentage = SD.GetOrderProgressPercentage(order.OrderStatus);
                var statusIcon = SD.GetOrderStatusIcon(order.OrderStatus);
                var statusBadgeClass = SD.GetOrderStatusBadgeClass(order.OrderStatus);

                <div class="col-12">
                    <div class="card shadow-sm">
                        <!-- Order Header -->
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <div>
                                <h5>Order #@order.Id</h5>
                                <small class="text-muted">@order.OrderDate.ToString("dd MMM yyyy 'at' HH:mm")</small>
                            </div>
                            <div>
                                <span class="badge @statusBadgeClass">
                                    <i class="bi @statusIcon"></i> @order.OrderStatus
                                </span>
                                <span class="badge @SD.GetPaymentStatusBadgeClass(order.PaymentStatus)">
                                    <i class="bi bi-credit-card"></i> @order.PaymentStatus
                                </span>
                            </div>
                        </div>

                        <!-- Order Body -->
                        <div class="card-body">
                            <div class="row">
                                <!-- Items -->
                                <div class="col-md-7">
                                    <h6 class="fw-bold mb-2">Items (@(order.OrderDetails?.Sum(d => d.Count) ?? 0))</h6>
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var item in order.OrderDetails.Take(3))
                                        {
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.ProductVariant?.Product?.ImageUrl))
                                                {
                                                    <img src="@item.ProductVariant.Product.ImageUrl"
                                                         alt="@item.ProductVariant.Product.Name"
                                                         class="rounded me-2"
                                                         style="width: 50px; height: 50px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-light rounded me-2 d-flex align-items-center justify-content-center"
                                                         style="width: 50px; height: 50px;">
                                                        <i class="bi bi-image text-muted"></i>
                                                    </div>
                                                }
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between">
                                                        <span>@(item.ProductVariant?.Product?.Name ?? "Product")</span>
                                                        <span class="text-muted">x@(item.Count)</span>
                                                    </div>
                                                    <div class="d-flex gap-2 mt-1">
                                                        @if (!string.IsNullOrEmpty(item.ProductVariant?.Color))
                                                        {
                                                            <span class="badge" style="background-color: @GetColorCode(item.ProductVariant?.Color); color: @GetTextColor(item.ProductVariant?.Color)">
                                                                @item.ProductVariant.Color
                                                            </span>
                                                        }
                                                        @if (item.ProductVariant?.SizeValue != null)
                                                        {
                                                            <span class="badge bg-secondary">@item.ProductVariant.SizeValue.DisplayText</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        @if (order.OrderDetails?.Count() > 3)
                                        {
                                            <small class="text-muted"><i class="bi bi-plus-circle"></i> @(order.OrderDetails.Count() - 3) more items</small>
                                        }
                                    </div>
                                </div>

                                <!-- Order Summary -->
                                <div class="col-md-5 mt-3 mt-md-0">
                                    <div class="bg-light p-3 rounded">
                                        <h6 class="fw-bold mb-2">Order Summary</h6>
                                        <div class="d-flex justify-content-between">
                                            <span>Subtotal:</span>
                                            <span>@order.OrderDetails.Sum(d => d.Price * d.Count).ToString("C", culture)</span>
                                        </div>
                                        <div class="d-flex justify-content-between">
                                            <span>Shipping:</span>
                                            <span class="text-success">Free</span>
                                        </div>
                                        <hr>
                                        <div class="d-flex justify-content-between fw-bold">
                                            <span>Total:</span>
                                            <span>@order.OrderTotal.ToString("C", culture)</span>
                                        </div>
                                        <!-- Country -->
                                        <div class="d-flex justify-content-between mt-2">
                                            <span>Country:</span>
                                            <span>@(order.Country ?? "—")</span>
                                        </div>

                                        <!-- QR Code Section -->
                                        <div class="mt-3 text-center">
                                            <h6 class="fw-bold mb-2">
                                                <i class="bi bi-qr-code text-primary"></i> Track Order
                                            </h6>
                                            @if (!string.IsNullOrEmpty(qrCodeBase64))
                                            {
                                                <div class="d-flex justify-content-center gap-2 align-items-center">
                                                    <img src="data:image/png;base64,@qrCodeBase64"
                                                         alt="QR Code"
                                                         style="width: 60px; height: 60px; cursor: pointer;"
                                                         onclick="window.open('@trackingUrl', '_blank')"
                                                         class="img-thumbnail"
                                                         title="Click to track" />
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('@trackingUrl')">
                                                        <i class="bi bi-link"></i> Copy Link
                                                    </button>
                                                </div>
                                                <small class="text-muted d-block mt-2">
                                                    <i class="bi bi-phone"></i> Scan to track
                                                </small>
                                                @if (order.OrderStatus == SD.StatusAwaitingShipmentApproval)
                                                {
                                                    <div class="alert alert-light small mt-2 mb-0">
                                                        <i class="bi bi-clock-history"></i>
                                                        Tracking details will appear after shipment approval.
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-muted small">
                                                    <i class="bi bi-qr-code"></i> QR code will be available soon
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Footer (updated with Pay Now for Company users) -->
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <div>
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                                @if (User.IsInRole(SD.Role_Company) && order.PaymentStatus == SD.PaymentStatusDeferred)
                                {
                                    <a asp-action="Payment" asp-route-orderId="@order.Id" class="btn btn-sm btn-success ms-2">
                                        <i class="bi bi-credit-card"></i> Pay Now
                                    </a>
                                }
                            </div>
                            @if (order.OrderStatus == SD.StatusPending || order.OrderStatus == SD.StatusAwaitingShipmentApproval)
                            {
                                <button class="btn btn-sm btn-outline-danger" onclick="cancelOrder(@order.Id)">Cancel</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function cancelOrder(orderId) {
            if (confirm('Are you sure you want to cancel this order?')) {
                $.post('@Url.Action("CancelOrder", "Order")', { id: orderId })
                    .done(function () { location.reload(); });
            }
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                alert('Tracking link copied to clipboard!');
            }).catch(function() {
                alert('Failed to copy link');
            });
        }
    </script>
    <style>
        .img-thumbnail {
            transition: transform 0.2s ease;
        }

            .img-thumbnail:hover {
                transform: scale(1.05);
            }
    </style>
}

@functions {
    public string GetColorCode(string? color) => color?.ToLower() switch
    {
        "red" => "#dc3545",
        "blue" => "#0d6efd",
        "green" => "#198754",
        "black" => "#212529",
        "white" => "#ffffff",
        "yellow" => "#ffc107",
        "purple" => "#6f42c1",
        "orange" => "#fd7e14",
        "brown" => "#795548",
        "navy" => "#001f3f",
        "pink" => "#d63384",
        "gray" or "grey" => "#6c757d",
        "tan" => "#d2b48c",
        _ => "#6c757d"
    };

    public string GetTextColor(string? color) => color?.ToLower() switch
    {
        "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
        _ => "#ffffff"
    };
}