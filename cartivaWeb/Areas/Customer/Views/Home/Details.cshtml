@using System.Globalization
@using ApplicationUtility
@using DataAccess
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _db
@model Models.Product

@{
    ViewData["Title"] = "Product Details";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    var userId = User.Identity?.IsAuthenticated == true ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : null;
    
    // Find the lowest price variant
    var lowestPriceVariant = Model.Variants?.OrderBy(v => v.Price).FirstOrDefault();
    var lowestPrice = lowestPriceVariant?.Price;
}

<link rel="stylesheet" href="~/css/home-details.css" asp-append-version="true" />

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Product Image -->
        <div class="col-md-6 text-center mb-3 mb-md-0">
            <div class="card">
                <div class="card-body p-2">
                    <div style="max-height:400px; overflow:hidden;">
                        <img src="@(Model.ImageUrl ?? "/images/no-image.png")"
                             class="img-fluid rounded"
                             style="width:auto; max-width:100%; object-fit:contain;"
                             alt="@Model.Name" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Details -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="text-primary">@Model.Name</h2>
                    <h5 class="text-muted">
                        <i class="bi bi-building"></i> @Model.Brand
                    </h5>
                    
                    <!-- Price Range Display -->
                    @if (Model.Variants != null && Model.Variants.Any())
                    {
                        var minPrice = Model.Variants.Min(v => v.Price);
                        var maxPrice = Model.Variants.Max(v => v.Price);
                        
                        <div class="mt-2 mb-3">
                            @if (minPrice == maxPrice)
                            {
                                <h3 class="text-primary fw-bold">@minPrice.ToString("C", culture)</h3>
                            }
                            else
                            {
                                <h3 class="text-primary fw-bold">
                                    @minPrice.ToString("C", culture) - @maxPrice.ToString("C", culture)
                                </h3>
                                <small class="text-muted">
                                    <i class="bi bi-tag"></i> Starting from @minPrice.ToString("C", culture)
                                </small>
                            }
                        </div>
                    }
                    
                    <hr />
                    
                    <p>
                        <strong><i class="bi bi-folder"></i> Category:</strong>
                        @(Model.Category?.Name ?? "No Category")
                    </p>
                    
                    @if (Model.Category?.DefaultSizeSystem != null)
                    {
                        <p>
                            <strong><i class="bi @(Model.Category.DefaultSizeSystem.IconClass ?? "bi-rulers")"></i> Size System:</strong>
                            <span class="badge bg-info">@Model.Category.DefaultSizeSystem.Name</span>
                            <small class="text-muted">(@Model.Category.DefaultSizeSystem.SizeType)</small>
                            @if (!string.IsNullOrEmpty(Model.Category.DefaultSizeSystem.Description))
                            {
                                <br />
                                <small class="text-muted">@Model.Category.DefaultSizeSystem.Description</small>
                            }
                        </p>
                    }
                    
                    <div class="mt-3">
                        <h6><i class="bi bi-card-text"></i> Description:</h6>
                        <p class="text-muted">@(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)</p>
                    </div>

                    @if (Model.Variants != null && Model.Variants.Any())
                    {
                        <hr />
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">
                                <i class="bi bi-boxes"></i> Available Variants
                                <span class="badge bg-secondary ms-2">@Model.Variants.Count</span>
                            </h5>
                            @if (lowestPriceVariant != null)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-star-fill me-1"></i> Best Price
                                </span>
                            }
                        </div>
                        
                        <div class="row" id="variants-container" data-add-to-cart-url="@Url.Action("AddToCart", "Cart")">
                            @foreach (var v in Model.Variants.OrderBy(v => v.Price))
                            {
                                var inCart = 0;
                                if (userId != null)
                                {
                                    var cartItem = _db.ShoppingCarts
                                                      .AsNoTracking()
                                                      .FirstOrDefault(c => c.ApplicationUserId == userId && c.ProductVariantId == v.Id);
                                    inCart = cartItem?.Count ?? 0;
                                }

                                var availableStock = v.Stock - inCart;
                                var isLowestPrice = lowestPriceVariant != null && v.Id == lowestPriceVariant.Id;

                                <div class="col-12 mb-3 variant-card" data-variant-id="@v.Id" data-stock="@v.Stock">
                                    <div class="card @(availableStock <= 0 ? "bg-light" : "") @(isLowestPrice ? "variant-best-price border-success border-2 shadow-sm" : "")">
                                        @if (isLowestPrice)
                                        {
                                            <div class="position-absolute top-0 end-0 mt-2 me-2">
                                                <span class="badge bg-success rounded-pill px-3 py-2">
                                                    <i class="bi bi-star-fill me-1"></i> Best Price
                                                </span>
                                            </div>
                                        }
                                        <div class="card-body p-3">
                                            <div class="row align-items-center">
                                                <div class="col-md-3">
                                                    <span class="badge d-block p-2" style="background-color: @GetColorCode(v.Color); color: @GetTextColor(v.Color);">
                                                        <i class="bi bi-droplet"></i> @v.Color
                                                    </span>
                                                </div>
                                                <div class="col-md-3">
                                                    @if (v.SizeValue != null)
                                                    {
                                                        <span class="badge bg-secondary d-block p-2">
                                                            <i class="bi bi-rulers"></i> @v.SizeValue.DisplayText
                                                        </span>
                                                        @if (!string.IsNullOrEmpty(v.SizeValue.Description))
                                                        {
                                                            <small class="text-muted d-block mt-1">@v.SizeValue.Description</small>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary d-block p-2">
                                                            <i class="bi bi-dash"></i> No size
                                                        </span>
                                                    }
                                                </div>
                                                <div class="col-md-2">
                                                    @if (isLowestPrice)
                                                    {
                                                        <div>
                                                            <strong class="text-success fs-5">@v.Price.ToString("C", culture)</strong>
                                                            <br />
                                                            <small class="text-success">Best deal!</small>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <strong class="text-primary">@v.Price.ToString("C", culture)</strong>
                                                    }
                                                </div>
                                                <div class="col-md-2">
                                                    @if (v.Stock > 10)
                                                    {
                                                        <span class="badge bg-success d-block p-2">
                                                            <i class="bi bi-check-circle"></i> <span class="stock-count">@availableStock</span> available
                                                        </span>
                                                    }
                                                    else if (v.Stock > 0)
                                                    {
                                                        <span class="badge bg-warning text-dark d-block p-2">
                                                            <i class="bi bi-exclamation-triangle"></i> Only <span class="stock-count">@availableStock</span> left
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger d-block p-2">
                                                            <i class="bi bi-x-circle"></i> Out of stock
                                                        </span>
                                                    }
                                                </div>
                                                <div class="col-md-2 text-end">
                                                    @if (availableStock > 0)
                                                    {
                                                        <div class="add-to-cart-wrapper">
                                                            <div class="input-group input-group-sm" style="width: 120px;">
                                                                <input type="number" class="form-control text-center quantity-input" value="1" min="1" max="@availableStock" />
                                                                <button type="button" class="btn @(isLowestPrice ? "btn-success" : "btn-primary") add-to-cart-btn" data-variant-id="@v.Id" data-max-stock="@availableStock">
                                                                    <i class="bi bi-cart-plus"></i>
                                                                </button>
                                                            </div>
                                                            <div class="add-to-cart-feedback small text-success mt-1" style="display: none;"></div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">
                                                            <i class="bi bi-cart-x"></i> Unavailable
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center py-4">
                            <i class="bi bi-box" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0">No variants available for this product.</p>
                        </div>
                    }

                    <div class="mt-4 d-flex flex-wrap gap-2">
                        <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="btn btn-warning">
                            <i class="bi bi-cart"></i> View Cart
                        </a>
                        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-arrow-left"></i> Back to Products
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Customer Reviews Section -->
    @{
        var allReviews = Model.Variants?
            .Where(v => v.Reviews != null)
            .SelectMany(v => v.Reviews!)
            .OrderByDescending(r => r.ReviewDate)
            .ToList() ?? new List<Review>();
        var avgRating = allReviews.Any() ? allReviews.Average(r => r.Rating) : 0;
    }

    <div class="row mt-4 mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">
                            <i class="bi bi-chat-quote"></i> Customer Reviews
                            <span class="badge bg-secondary ms-1">@allReviews.Count</span>
                        </h5>
                        @if (allReviews.Any())
                        {
                            <div>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(avgRating))
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-muted"></i>
                                    }
                                }
                                <span class="ms-1 fw-bold">@avgRating.ToString("0.0")</span>
                                <small class="text-muted">(@allReviews.Count reviews)</small>
                            </div>
                        }
                    </div>

                    @if (!allReviews.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-chat-dots" style="font-size: 2.5rem;"></i>
                            <p class="mt-2 mb-0">No reviews yet. Be the first to review this product!</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var review in allReviews)
                        {
                            var variant = Model.Variants?.FirstOrDefault(v => v.Id == review.ProductVariantId);
                            <div class="border-bottom py-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <strong>
                                                <i class="bi bi-person-circle"></i>
                                                @(review.ApplicationUser?.Name ?? "Customer")
                                            </strong>
                                            @if (variant != null)
                                            {
                                                <span class="badge bg-light text-dark border">
                                                    @variant.Color
                                                    @if (variant.SizeValue != null)
                                                    {
                                                        <span>/ @variant.SizeValue.DisplayText</span>
                                                    }
                                                </span>
                                            }
                                        </div>
                                        <div>
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="bi bi-star-fill text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star text-muted"></i>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">@review.ReviewDate.ToString("dd MMM yyyy")</small>
                                </div>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p class="mt-2 mb-0 text-muted">@review.Comment</p>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/home-details.js" asp-append-version="true"></script>
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}