@model Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">

    @* Success message *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <img src="@(Model.ImageUrl ?? "/images/no-image.png")"
                 class="img-fluid rounded shadow-sm"
                 style="max-height:400px; object-fit:cover;"
                 alt="@Model.Name" />
        </div>

        <div class="col-md-6">
            <h2>@Model.Name</h2>
            <h5 class="text-muted">@Model.Brand</h5>
            <p><strong>Category:</strong> @(Model.Category?.Name ?? "No Category")</p>
            <p>@(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)</p>

            @if (Model.Variants != null && Model.Variants.Any())
            {
                <h5>Variants:</h5>
                <ul class="list-unstyled">
                    @foreach (var v in Model.Variants)
                    {
                        <li class="mb-2 p-2 border rounded">
                            <span class="badge bg-primary me-1">Color: @v.Color</span>
                            <span class="badge bg-secondary me-1">Size: @v.Size</span>
                            <span class="badge bg-success me-1">Price: @v.Price.ToString("C")</span>
                            <span class="badge bg-warning me-1">Stock: @v.Stock</span>

                            @if (v.Stock > 0)
                            {
                                <form asp-area="Customer"
                                      asp-controller="Home"
                                      asp-action="AddToCart"
                                      method="post"
                                      class="d-inline-block ms-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productVariantId" value="@v.Id" />
                                    <input type="number" name="count" value="1" min="1" max="@v.Stock" class="form-control d-inline-block" style="width:70px;" />
                                    <button type="submit" class="btn btn-sm btn-success mt-1">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-danger ms-2">Out of stock</span>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p>No variants available.</p>
            }

            <div class="mt-3">
                <a asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Cart"
                       class="btn btn-warning me-2">
                    <i class="bi bi-cart"></i> View Cart
                </a>

                <a asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-primary">
                    <i class="bi bi-arrow-left"></i> Back to Products
                </a>
            </div>
        </div>
    </div>

</div>