@using System.Globalization
@using DataAccess
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _db
@model Models.Product

@{
    ViewData["Title"] = "Product Details";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    var userId = User.Identity?.IsAuthenticated == true ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : null;
}

<div class="container mt-4">

    @* Success message *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Product Image -->
        <div class="col-md-6 text-center mb-3 mb-md-0">
            <div style="max-height:400px; overflow:hidden;">
                <img src="@(Model.ImageUrl ?? "/images/no-image.png")"
                     class="img-fluid rounded shadow-sm"
                     style="width:auto; max-width:100%; object-fit:contain;"
                     alt="@Model.Name" />
            </div>
        </div>

        <!-- Product Details -->
        <div class="col-md-6">
            <h2>@Model.Name</h2>
            <h5 class="text-muted">@Model.Brand</h5>
            <p><strong>Category:</strong> @(Model.Category?.Name ?? "No Category")</p>
            <p>@(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)</p>

            @if (Model.Variants != null && Model.Variants.Any())
            {
                <h5>Variants:</h5>
                <ul class="list-unstyled">
                    @foreach (var v in Model.Variants)
                    {
                        var inCart = 0;
                        if (userId != null)
                        {
                            // get quantity in cart
                            var cartItem = _db.ShoppingCarts
                                              .AsNoTracking()
                                              .FirstOrDefault(c => c.ApplicationUserId == userId && c.ProductVariantId == v.Id);
                            inCart = cartItem?.Count ?? 0;
                        }

                        var availableStock = v.Stock - inCart;

                        <li class="mb-2 p-2 border rounded d-flex flex-wrap align-items-center">
                            <span class="badge bg-primary me-1 mb-1">Color: @v.Color</span>
                            <span class="badge bg-secondary me-1 mb-1">Size: @v.Size</span>
                            <span class="badge bg-success me-1 mb-1">Price: @v.Price.ToString("C", culture)</span>
                            <span class="badge bg-warning me-1 mb-1">Available: @availableStock</span>

                            @if (availableStock > 0)
                            {
                                <form asp-area="Customer"
                                      asp-controller="Cart"
                                      asp-action="AddToCart"
                                      method="post"
                                      class="d-flex align-items-center ms-2 mb-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productVariantId" value="@v.Id" />
                                    <input type="number" name="count" value="1" min="1" max="@availableStock"
                                           class="form-control d-inline-block me-1" style="width:70px;" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-danger ms-2 mb-1">Out of stock</span>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p>No variants available.</p>
            }

            <div class="mt-3 d-flex flex-wrap">
                <a asp-area="Customer"
                       asp-controller="Cart"
                       asp-action="Index"
                       class="btn btn-warning me-2 mb-2">
                    <i class="bi bi-cart"></i> View Cart
                </a>

                <a asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-primary mb-2">
                    <i class="bi bi-arrow-left"></i> Back to Products
                </a>
            </div>
        </div>
    </div>

</div>