@using System.Globalization
@using ApplicationUtility
@model IEnumerable<Models.Product>

@{
    ViewData["Title"] = "Home";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="container-fluid mt-4 px-2">

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col text-center">
            <h2 class="fw-bold">Our Products</h2>
            <p class="text-muted">Browse our latest products</p>
        </div>
    </div>

    <!-- Product Grid -->
    <div class="row g-3 justify-content-start">
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                // Calculate lowest price from variants
                var lowestPrice = product.Variants != null && product.Variants.Any()
                    ? product.Variants.Min(v => v.Price)
                    : (decimal?)null;

                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="card h-100 shadow-sm position-relative">

                        <!-- Optional: Sale Badge -->
                        @if (lowestPrice.HasValue && lowestPrice.Value < 100)
                        {
                            <span class="badge bg-danger position-absolute top-0 end-0 m-2 px-2 py-1">
                                <i class="bi bi-tag"></i> Sale
                            </span>
                        }

                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/no-image.png" : product.ImageUrl)"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;"
                             alt="@product.Name" />

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">@product.Name</h5>
                            <p class="text-muted mb-1"><strong>Brand:</strong> @product.Brand</p>
                            <p class="text-muted mb-1"><strong>Category:</strong> @(product.Category?.Name ?? "No Category")</p>
                            
                            <!-- Price Display -->
                            @if (lowestPrice.HasValue)
                            {
                                <div class="mb-2">
                                    <span class="h5 text-primary fw-bold">@lowestPrice.Value.ToString("C", culture)</span>
                                    <small class="text-muted">
                                        @if (product.Variants.Count() > 1)
                                        {
                                            <span>+ @(product.Variants.Count() - 1) more</span>
                                        }
                                    </small>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-2">
                                    <i class="bi bi-exclamation-circle"></i> No variants available
                                </p>
                            }

                            <p class="card-text small mb-2">
                                @(string.IsNullOrEmpty(product.Description) ? "No description available." : product.Description)
                            </p>

                            <!-- View Details -->
                            <a asp-area="Customer"
                                   asp-controller="Home"
                                   asp-action="Details"
                                   asp-route-id="@product.Id"
                                   class="btn btn-dark mt-auto">
                                <i class="bi bi-eye"></i> View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col text-center">
                <p class="text-muted">No products available.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Add any client-side functionality
        console.log('Home page loaded');
    </script>
}