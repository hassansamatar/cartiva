@model Models.ViewModels.ProductVariantVM

@{
    ViewData["Title"] = "Create Variant";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-primary">
                <i class="bi @(Model.SizeSystem?.IconClass ?? "bi-box")"></i>
                Create @(Model.SizeSystem?.Name ?? "Product") Variant for @Model.ProductName
            </h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <form asp-controller="Product" asp-action="CreateProductVariant" method="post">
                <input type="hidden" asp-for="Variant.ProductId" />
                
                <!-- Size System Info Banner -->
                @if (Model.SizeSystem != null)
                {
                    <div class="alert @(Model.SizeSystem.AlertClass ?? "alert-info") mb-4">
                        <i class="bi @(Model.SizeSystem.IconClass ?? "bi-info-circle") me-2"></i>
                        <strong>@Model.SizeSystem.Description</strong>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Accessory Product</strong> - This product does not require size selection.
                    </div>
                }

                <!-- Color Selection -->
                <div class="mb-3">
                    <label asp-for="Variant.Color" class="form-label fw-bold"></label>
                    <select asp-for="Variant.Color" class="form-select" asp-items="Model.AvailableColors">
                        <option value="">-- Select Color --</option>
                    </select>
                    <span asp-validation-for="Variant.Color" class="text-danger"></span>
                </div>

                <!-- Size Selection - Only show if size system exists -->
                @if (Model.SizeSystem != null)
                {
                    <div class="mb-3">
                        <label asp-for="Variant.SizeValueId" class="form-label fw-bold">Size</label>
                        <select asp-for="Variant.SizeValueId" class="form-select" asp-items="Model.AvailableSizes">
                            <option value="">-- Select Size --</option>
                        </select>
                        <span asp-validation-for="Variant.SizeValueId" class="text-danger"></span>
                        
                        <!-- Size helper text from SizeSystem -->
                        <small class="text-muted">
                            @(Model.SizeSystem.SizeType switch
                            {
                                "Kid" => "Select size in cm (height)",
                                "Suit" => "EU chest measurement",
                                "Shoe" => "EU shoe size",
                                _ => "Standard letter size"
                            })
                        </small>
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="Variant.SizeValueId" value="" />
                    <div class="alert alert-secondary mb-3">
                        <i class="bi bi-gem me-2"></i>
                        <strong>Accessory Item</strong> - This variant will not have a size option.
                    </div>
                }

                <!-- Price -->
                <div class="mb-3">
                    <label asp-for="Variant.Price" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">kr</span>
                        <input asp-for="Variant.Price" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="Variant.Price" class="text-danger"></span>
                </div>

                <!-- Stock -->
                <div class="mb-3">
                    <label asp-for="Variant.Stock" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-box"></i>
                        </span>
                        <input asp-for="Variant.Stock" class="form-control" type="number" min="0" />
                    </div>
                    <span asp-validation-for="Variant.Stock" class="text-danger"></span>
                </div>

                <!-- Form Actions -->
                <div class="mb-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Create Variant
                    </button>
                    <a asp-controller="Product"
                           asp-action="VariantIndex"
                           asp-route-productId="@Model.Variant.ProductId"
                           class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>

        <!-- Information Column -->
        <div class="col-md-5 offset-md-1">
            @if (Model.SizeSystem != null)
            {
                <!-- Size Information Card -->
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi @(Model.SizeSystem.IconClass ?? "bi-info-circle") me-2"></i>
                            @Model.SizeSystem.Name Size Guide
                        </h5>
                    </div>
                    <div class="card-body">
                        @switch (Model.SizeSystem.SizeType)
                        {
                            case "Kid":
                                <h6>Kids Size Guide (EU):</h6>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><span class="badge bg-secondary me-2">50-68</span> 0-6 months</li>
                                    <li class="mb-2"><span class="badge bg-secondary me-2">74-86</span> 6-18 months</li>
                                    <li class="mb-2"><span class="badge bg-secondary me-2">92-104</span> 2-4 years</li>
                                    <li class="mb-2"><span class="badge bg-secondary me-2">110-122</span> 5-7 years</li>
                                    <li class="mb-2"><span class="badge bg-secondary me-2">128-140</span> 8-10 years</li>
                                    <li class="mb-2"><span class="badge bg-secondary me-2">146-158</span> 11-13 years</li>
                                    <li class="mb-2"><span class="badge bg-secondary me-2">164-176</span> 14-16 years</li>
                                </ul>
                                break;
                                
                            case "Suit":
                                <h6>Suit Size Guide (EU):</h6>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><span class="badge bg-primary me-2">44</span> UK 34" / XS</li>
                                    <li class="mb-2"><span class="badge bg-primary me-2">46</span> UK 36" / S</li>
                                    <li class="mb-2"><span class="badge bg-primary me-2">48</span> UK 38" / M</li>
                                    <li class="mb-2"><span class="badge bg-primary me-2">50</span> UK 40" / L</li>
                                    <li class="mb-2"><span class="badge bg-primary me-2">52</span> UK 42" / XL</li>
                                    <li class="mb-2"><span class="badge bg-primary me-2">54</span> UK 44" / XXL</li>
                                    <li class="mb-2"><span class="badge bg-primary me-2">56</span> UK 46" / XXXL</li>
                                </ul>
                                break;
                                
                            case "Shoe":
                                <h6>Shoe Size Guide (EU):</h6>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><span class="badge bg-success me-2">35-36</span> UK 2.5-3.5 / US 5-6</li>
                                    <li class="mb-2"><span class="badge bg-success me-2">37-38</span> UK 4.5-5.5 / US 7-8</li>
                                    <li class="mb-2"><span class="badge bg-success me-2">39-40</span> UK 6.5-7.5 / US 9-10</li>
                                    <li class="mb-2"><span class="badge bg-success me-2">41-42</span> UK 8.5-9.5 / US 11-12</li>
                                    <li class="mb-2"><span class="badge bg-success me-2">43-44</span> UK 10.5-11.5 / US 13-14</li>
                                    <li class="mb-2"><span class="badge bg-success me-2">45-46</span> UK 12.5-13.5 / US 15-16</li>
                                </ul>
                                break;
                                
                            default: // Regular
                                     <h6>Regular Size Guide:</h6>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><span class="badge bg-info me-2">XS</span> Extra Small</li>
                                    <li class="mb-2"><span class="badge bg-info me-2">S</span> Small</li>
                                    <li class="mb-2"><span class="badge bg-info me-2">M</span> Medium</li>
                                    <li class="mb-2"><span class="badge bg-info me-2">L</span> Large</li>
                                    <li class="mb-2"><span class="badge bg-info me-2">XL</span> Extra Large</li>
                                    <li class="mb-2"><span class="badge bg-info me-2">XXL</span> Double Extra Large</li>
                                </ul>
                                break;
                        }
                        
                        <!-- Available Sizes -->
                        @if (Model.AvailableSizes != null && Model.AvailableSizes.Any())
                        {
                            <hr />
                            <h6>Available Sizes:</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var size in Model.AvailableSizes.Where(s => !string.IsNullOrEmpty(s.Value)))
                                {
                                    <span class="badge bg-light text-dark border p-2">
                                        @size.Text
                                    </span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Accessory Information Card -->
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-gem me-2"></i>
                            Accessory Information
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="bi bi-gem" style="font-size: 3rem; color: #6c757d;"></i>
                        </div>
                        <p class="text-muted">
                            This product is in a category without a size system.
                        </p>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                No size selection needed
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Variants differ only by color
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Perfect for accessories, bags, jewelry
                            </li>
                        </ul>
                        <hr />
                        <p class="small text-muted mb-0">
                            <i class="bi bi-lightbulb"></i>
                            You can create multiple color variants for this accessory.
                        </p>
                    </div>
                </div>
            }
            
            <!-- Preview Card -->
            <div class="card mt-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-eye me-2"></i>
                        Preview
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center">
                        <i class="bi bi-box-seam text-primary" style="font-size: 2rem;"></i>
                        <h6 class="mt-2" id="previewName">@Model.ProductName</h6>
                        <div id="previewDetails" class="small text-muted">
                            <span id="previewColor">No color selected</span>
                            @if (Model.SizeSystem != null)
                            {
                                <span> • <span id="previewSize">No size selected</span></span>
                            }
                        </div>
                        <div class="mt-2">
                            <span id="previewPrice" class="fw-bold text-primary">kr 0,00</span>
                            <span id="previewStock" class="ms-2 badge bg-secondary">Stock: 0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Live preview updates
            $('#Variant_Color').change(function() {
                var selectedColor = $(this).find('option:selected').text();
                $('#previewColor').text(selectedColor || 'No color selected');
            });
            
            @if (Model.SizeSystem != null)
            {
                        <text>
                                $('#Variant_SizeValueId').change(function() {
                                    var selectedSize = $(this).find('option:selected').text();
                                    $('#previewSize').text(selectedSize || 'No size selected');
                                });
                        </text>
            }
            
            $('#Variant_Price').on('input', function() {
                var price = parseFloat($(this).val()) || 0;
                $('#previewPrice').text('kr ' + price.toFixed(2).replace('.', ','));
            });
            
            $('#Variant_Stock').on('input', function() {
                var stock = parseInt($(this).val()) || 0;
                $('#previewStock').text('Stock: ' + stock);
                if (stock > 10) {
                    $('#previewStock').removeClass('bg-warning bg-danger').addClass('bg-success');
                } else if (stock > 0) {
                    $('#previewStock').removeClass('bg-success bg-danger').addClass('bg-warning');
                } else {
                    $('#previewStock').removeClass('bg-success bg-warning').addClass('bg-danger');
                }
            });
            
            // Focus on first field
            $('#Variant_Color').focus();
        });
    </script>
}