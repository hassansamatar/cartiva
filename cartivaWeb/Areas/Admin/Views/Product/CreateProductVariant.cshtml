@model Models.ViewModels.ProductVariantVM

@{
    ViewData["Title"] = "Create Variant";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-primary">Create New Variant for @ViewBag.ProductName</h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="CreateProductVariant" method="post">
                <input type="hidden" asp-for="Variant.ProductId" />
                <input type="hidden" name="sizeGroup" value="@ViewBag.SizeGroup" />

                <!-- Display Size Group Info -->
                <div class="alert alert-info mb-3">
                    <strong>Size Group:</strong> @(ViewBag.SizeGroup == "Kid" ? "Kids Sizes (2-5 Years)" : "Adult Sizes (S, M, L, XL, XXL)")
                </div>

                <!-- Color -->
                <div class="mb-3">
                    <label asp-for="Variant.Color" class="form-label fw-bold"></label>
                    <select asp-for="Variant.Color" class="form-select" asp-items="Model.AvailableColors">
                        <option value="">-- Select Color --</option>
                    </select>
                    <span asp-validation-for="Variant.Color" class="text-danger"></span>
                </div>

                <!-- Size -->
                <div class="mb-3">
                    <label asp-for="Variant.Size" class="form-label fw-bold"></label>
                    <select asp-for="Variant.Size" class="form-select" asp-items="Model.AvailableSizes">
                        <option value="">-- Select Size --</option>
                    </select>
                    <span asp-validation-for="Variant.Size" class="text-danger"></span>
                    
                    @if (ViewBag.SizeGroup == "Kid")
                    {
                        <small class="text-info">Available kid sizes: 2 Years, 3 Years, 4 Years, 5 Years</small>
                    }
                    else
                    {
                        <small class="text-info">Available adult sizes: S, M, L, XL, XXL</small>
                    }
                </div>

                <!-- Price -->
                <div class="mb-3">
                    <label asp-for="Variant.Price" class="form-label fw-bold"></label>
                    <input asp-for="Variant.Price" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Variant.Price" class="text-danger"></span>
                </div>

                <!-- Stock -->
                <div class="mb-3">
                    <label asp-for="Variant.Stock" class="form-label fw-bold"></label>
                    <input asp-for="Variant.Stock" class="form-control" type="number" min="0" />
                    <span asp-validation-for="Variant.Stock" class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Create Variant
                    </button>
                    <a asp-action="VariantIndex" asp-route-productId="@Model.Variant.ProductId" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}