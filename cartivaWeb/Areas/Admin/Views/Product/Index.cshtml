@model IEnumerable<Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">
                <i class="bi bi-box-seam"></i> Product List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Upsert" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Product
            </a>
        </div>
    </div>
    <br /><br />

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Category</th>
                    <th>Size System</th>
                    <th>Variants</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td style="width: 8%">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" style="width:50px; height:50px; border-radius:5px; object-fit:cover" />
                            }
                            else
                            {
                                <img src="/images/products/no-image.png" style="width:50px; height:50px; border-radius:5px; object-fit:cover" />
                            }
                        </td>
                        <td style="width: 18%">
                            <i class="bi bi-tag text-primary me-1"></i>
                            @product.Name
                        </td>
                        <td style="width: 12%">@product.Brand</td>
                        <td style="width: 12%">
                            <span class="badge bg-light text-dark">
                                <i class="bi bi-folder me-1"></i>
                                @(product.Category?.Name ?? "N/A")
                            </span>
                        </td>
                        <td style="width: 12%">
                            @if (product.Category?.DefaultSizeSystem != null)
                            {
                                <div class="d-flex align-items-center">
                                    <i class="bi @(product.Category.DefaultSizeSystem.IconClass ?? "bi-tag") me-2 text-info"></i>
                                    <span class="badge bg-info"
                                          data-bs-toggle="tooltip"
                                          title="@product.Category.DefaultSizeSystem.Description">
                                        @product.Category.DefaultSizeSystem.Name
                                    </span>
                                    <small class="ms-1 text-muted">(@product.Category.DefaultSizeSystem.SizeType)</small>
                                </div>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-dash"></i> No size system
                                </span>
                            }
                        </td>
                        <td style="width: 8%" class="text-center">
                            @if (product.Variants != null && product.Variants.Any())
                            {
                                <span class="badge bg-success">@product.Variants.Count</span>
                                <small class="d-block text-muted mt-1">
                                    @{
                                        var firstVariant = product.Variants.FirstOrDefault();
                                        if (firstVariant?.SizeValue?.SizeSystem != null)
                                        {
                                            <span><i class="bi bi-rulers"></i> @firstVariant.SizeValue.SizeSystem.SizeType</span>
                                        }
                                        else if (product.Category?.DefaultSizeSystem == null)
                                        {
                                            <span class="text-muted"><i class="bi bi-dash"></i> No sizes</span>
                                        }
                                    }
                                </small>
                            }
                            else if (product.Category?.DefaultSizeSystem != null)
                            {
                                <span class="badge bg-warning text-dark">0</span>
                                <small class="d-block text-muted mt-1">
                                    <i class="bi bi-exclamation-circle"></i> No variants
                                </small>
                            }
                            else
                            {
                                <span class="badge bg-secondary">—</span>
                                <small class="d-block text-muted mt-1">
                                    <i class="bi bi-box"></i> Accessory
                                </small>
                            }
                        </td>
                        <td style="width: 30%">
                            <div class="btn-group" role="group">
                                <a asp-action="Upsert" asp-route-id="@product.Id" class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this product?')">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                                <a asp-action="VariantIndex" asp-route-productId="@product.Id" class="btn btn-info btn-sm">
                                    <i class="bi bi-list"></i> Variants
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-box-seam" style="font-size: 4rem;"></i>
            <h5 class="mt-3">No products found</h5>
            <p>Click the "Add New Product" button to create your first product.</p>
            <a asp-action="Upsert" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle"></i> Add New Product
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/admin-product-index.js" asp-append-version="true"></script>
}