@model IEnumerable<Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Product List</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Upsert" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Product
            </a>
        </div>
    </div>
    <br /><br />

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Category</th>
                    <th>Variants Count</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td style="width: 10%">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" style="width:50px; height:50px; border-radius:5px; object-fit:cover" />
                            }
                            else
                            {
                                <img src="/images/products/no-image.png" style="width:50px; height:50px; border-radius:5px; object-fit:cover" />
                            }
                        </td>
                        <td style="width: 20%">@product.Name</td>
                        <td style="width: 15%">@product.Brand</td>
                        <td style="width: 15%">
                            @(product.Category?.Name ?? "N/A")
                        </td>
                        <td style="width: 10%" class="text-center">
                            @if (product.Variants != null)
                            {
                                <span class="badge bg-info">@product.Variants.Count</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">0</span>
                            }
                        </td>
                        <td style="width: 30%">
                            <div class="btn-group" role="group">
                                <a asp-action="Upsert" asp-route-id="@product.Id" class="btn btn-warning btn-sm mx-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm mx-1"
                                       onclick="return confirm('Are you sure you want to delete this product?')">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                                <a asp-action="VariantIndex" asp-route-productId="@product.Id" class="btn btn-info btn-sm mx-1">
                                    <i class="bi bi-list"></i> Variants
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info text-center">
            <h5>No products found.</h5>
            <p>Click the "Add New Product" button to create your first product.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Optional: Add any custom JavaScript for the index page
    </script>
}