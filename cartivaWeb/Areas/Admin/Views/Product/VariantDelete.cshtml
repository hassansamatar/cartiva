@model Models.ViewModels.ProductVariant
   
@using System.Globalization

@{
    ViewData["Title"] = "Delete Variant";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-danger">Delete Variant</h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h5>Are you sure you want to delete this variant?</h5>

            <dl class="row">
                <dt class="col-sm-4">Color</dt>
                <dd class="col-sm-8">@Model.Color</dd>

                <dt class="col-sm-4">Size</dt>
                <dd class="col-sm-8">@Model.Size</dd>

                <dt class="col-sm-4">Price</dt>
             

<dd class="col-sm-8">@(@Model.Price.ToString("C", CultureInfo.GetCultureInfo("en-US")))</dd>

                <dt class="col-sm-4">Stock</dt>
                <dd class="col-sm-8">@Model.Stock</dd>
            </dl>

            <form asp-action="VariantDelete" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ProductId" />
                
                <div class="mb-3">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="VariantIndex" asp-route-productId="@Model.ProductId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>