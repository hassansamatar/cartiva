@using System.Globalization
@using ApplicationUtility
@model Models.ViewModels.ProductVariantVM

@{
    ViewData["Title"] = "Edit Variant";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-primary">
                <i class="bi @(Model.SizeSystem?.IconClass ?? "bi-box")"></i>
                Edit @(Model.SizeSystem?.Name ?? "Product") Variant for @Model.ProductName
            </h2>
            <hr />
        </div>
    </div>

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <form asp-controller="Product" asp-action="EditProductVariant" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Variant.Id" />
                <input type="hidden" asp-for="Variant.ProductId" />
                
                <!-- Size System Info Banner -->
                @if (Model.SizeSystem != null)
                {
                    <div class="alert @(Model.SizeSystem.AlertClass ?? "alert-info") mb-4">
                        <i class="bi @(Model.SizeSystem.IconClass ?? "bi-info-circle") me-2"></i>
                        <strong>@Model.SizeSystem.Description</strong>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Accessory Product</strong> - This product does not require size selection.
                    </div>
                }

                <!-- Color Selection -->
                <div class="mb-3">
                    <label asp-for="Variant.Color" class="form-label fw-bold"></label>
                    <select asp-for="Variant.Color" class="form-select" asp-items="Model.AvailableColors">
                        <option value="">-- Select Color --</option>
                    </select>
                    <span asp-validation-for="Variant.Color" class="text-danger"></span>
                </div>

                <!-- Size Selection - Only show if size system exists -->
                @if (Model.SizeSystem != null)
                {
                    <div class="mb-3">
                        <label asp-for="Variant.SizeValueId" class="form-label fw-bold">Size</label>
                        <select asp-for="Variant.SizeValueId" class="form-select" asp-items="Model.AvailableSizes">
                            <option value="">-- Select Size --</option>
                        </select>
                        <span asp-validation-for="Variant.SizeValueId" class="text-danger"></span>
                        
                        <!-- Size helper text from SizeSystem -->
                        <small class="text-muted">
                            @(Model.SizeSystem.SizeType switch
                            {
                                "Kid" => "Select size in cm (height)",
                                "Suit" => "EU chest measurement",
                                "Shoe" => "EU shoe size",
                                _ => "Standard letter size"
                            })
                        </small>
                        
                        <!-- Show current size info -->
                        @if (Model.Variant.SizeValue != null)
                        {
                            <div class="mt-2 p-2 bg-light rounded border-start border-3 border-info">
                                <small class="text-info">
                                    <i class="bi bi-info-circle"></i>
                                    <strong>Current size:</strong> @Model.Variant.SizeValue.DisplayText
                                    @if (!string.IsNullOrEmpty(Model.Variant.SizeValue.Description))
                                    {
                                        <span class="text-muted"> - @Model.Variant.SizeValue.Description</span>
                                    }
                                </small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="Variant.SizeValueId" value="" />
                    <div class="alert alert-secondary mb-3">
                        <i class="bi bi-gem me-2"></i>
                        <strong>Accessory Item</strong> - This variant does not have a size option.
                    </div>
                }

                <!-- Price -->
                <div class="mb-3">
                    <label asp-for="Variant.Price" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">kr</span>
                        <input asp-for="Variant.Price" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="Variant.Price" class="text-danger"></span>
                </div>

                <!-- Stock -->
                <div class="mb-3">
                    <label asp-for="Variant.Stock" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-box"></i>
                        </span>
                        <input asp-for="Variant.Stock" class="form-control" type="number" min="0" />
                    </div>
                    <span asp-validation-for="Variant.Stock" class="text-danger"></span>
                </div>

                <!-- Form Actions -->
                <div class="mb-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Update Variant
                    </button>
                    <a asp-controller="Product"
                           asp-action="VariantIndex"
                           asp-route-productId="@Model.Variant.ProductId"
                           class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>

        <!-- Preview Column -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-eye me-2"></i>
                        Live Preview
                    </h5>
                </div>
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-box-seam" style="font-size: 4rem; color: #0d6efd;"></i>
                    </div>
                    
                    <h6 class="fw-bold" id="previewName">@Model.ProductName</h6>
                    
                    <div class="mt-3">
                        <!-- Color Badge -->
                        <span class="badge d-inline-block mb-2" id="previewColorBadge"
                              style="background-color: @(GetColorCode(Model.Variant.Color));
                            color: @(GetTextColor(Model.Variant.Color));
                            padding: 0.5rem 1rem;">
                            <i class="bi bi-droplet me-1"></i>
                            <span id="previewColorText">@Model.Variant.Color</span>
                        </span>
                        
                        <!-- Size Badge -->
                        @if (Model.SizeSystem != null)
                        {
                            <span class="badge bg-secondary d-inline-block mb-2 ms-1" id="previewSizeBadge"
                                  style="padding: 0.5rem 1rem; @(Model.Variant.SizeValue == null ? "display: none;" : "")">
                                <i class="bi bi-rulers me-1"></i>
                                <span id="previewSizeText">@(Model.Variant.SizeValue?.DisplayText ?? "No size")</span>
                            </span>
                        }
                    </div>
                    
                    <!-- Price and Stock -->
                    <div class="mt-3 p-3 bg-light rounded">
                        <div class="row">
                            <div class="col-6">
                                <small class="text-muted">Price</small>
                                <h5 class="text-primary mb-0" id="previewPrice">
                                    @Model.Variant.Price.ToString("C", culture)
                                </h5>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Stock</small>
                                <h5 class="mb-0" id="previewStock">
                                    @if (Model.Variant.Stock > 10)
                                    {
                                        <span class="text-success">@Model.Variant.Stock</span>
                                    }
                                    else if (Model.Variant.Stock > 0)
                                    {
                                        <span class="text-warning">@Model.Variant.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">Out of Stock</span>
                                    }
                                </h5>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Size System Info -->
                    @if (Model.SizeSystem != null)
                    {
                        <div class="mt-2 small text-muted">
                            <i class="bi @(Model.SizeSystem.IconClass ?? "bi-tag")"></i>
                            @Model.SizeSystem.Name (@Model.SizeSystem.SizeType)
                        </div>
                    }
                    else
                    {
                        <div class="mt-2 small text-muted">
                            <i class="bi bi-gem"></i> Accessory Item
                        </div>
                    }
                </div>
            </div>
            
            <!-- Available Sizes Card -->
            @if (Model.SizeSystem != null && Model.AvailableSizes != null && Model.AvailableSizes.Any())
            {
                <div class="card mt-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">
                            <i class="bi bi-list-ul me-2"></i>
                            Available Sizes
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var size in Model.AvailableSizes.Where(s => !string.IsNullOrEmpty(s.Value)))
                            {
                                var isSelected = size.Value == Model.Variant.SizeValueId?.ToString();
                                <span class="badge @(isSelected ? "bg-primary" : "bg-light text-dark border") p-2"
                                      style="cursor: pointer; @(isSelected ? "" : "opacity: 0.8;")"
                                      onclick="selectSize('@size.Value', '@size.Text')">
                                    @size.Text
                                    @if (isSelected)
                                    {
                                        <i class="bi bi-check-circle-fill ms-1 text-white"></i>
                                    }
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
            
            <!-- Quick Stats Card -->
            <div class="card mt-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0">
                        <i class="bi bi-bar-chart me-2"></i>
                        Quick Stats
                    </h6>
                </div>
                <div class="card-body small">
                    <p class="mb-1">
                        <i class="bi bi-tag"></i> <strong>Category:</strong> @ViewBag.CategoryName
                    </p>
                    <p class="mb-1">
                        <i class="bi bi-boxes"></i> <strong>Total Variants:</strong> @ViewBag.TotalVariants
                    </p>
                    <p class="mb-0">
                        <i class="bi bi-currency-exchange"></i> <strong>Value:</strong>
                        @((Model.Variant.Price * Model.Variant.Stock).ToString("C", culture))
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Live preview update on color change
            $('#Variant_Color').change(function() {
                var selectedColor = $(this).find('option:selected').text();
                var selectedValue = $(this).val();
                
                $('#previewColorText').text(selectedColor);
                
                // Update badge color (you'd need a mapping function here)
                console.log('Color changed to: ' + selectedColor);
            });
            
            @if (Model.SizeSystem != null)
            {
                        <text>
                                // Live preview update on size change
                                $('#Variant_SizeValueId').change(function() {
                                    var selectedOption = $(this).find('option:selected');
                                    var selectedText = selectedOption.text();
                                    var selectedValue = $(this).val();
                    
                                    if (selectedValue) {
                                        $('#previewSizeText').text(selectedText);
                                        $('#previewSizeBadge').show();
                                    } else {
                                        $('#previewSizeText').text('No size');
                                        $('#previewSizeBadge').hide();
                                    }
                    
                                    console.log('Size changed to: ' + selectedText);
                                });
                        </text>
            }
            
            // Live preview update on price change
            $('#Variant_Price').on('input', function() {
                var price = parseFloat($(this).val()) || 0;
                var formattedPrice = 'kr ' + price.toFixed(2).replace('.', ',');
                $('#previewPrice').text(formattedPrice);
                
                // Update value calculation
                updateTotalValue();
            });
            
            // Live preview update on stock change
            $('#Variant_Stock').on('input', function() {
                var stock = parseInt($(this).val()) || 0;
                var stockElement = $('#previewStock');
                
                if (stock > 10) {
                    stockElement.html('<span class="text-success">' + stock + '</span>');
                } else if (stock > 0) {
                    stockElement.html('<span class="text-warning">' + stock + '</span>');
                } else {
                    stockElement.html('<span class="text-danger">Out of Stock</span>');
                }
                
                updateTotalValue();
            });
            
            function updateTotalValue() {
                var price = parseFloat($('#Variant_Price').val()) || 0;
                var stock = parseInt($('#Variant_Stock').val()) || 0;
                var total = price * stock;
                $('.card-body small:contains("Value:")').html(
                    '<i class="bi bi-currency-exchange"></i> <strong>Value:</strong> ' +
                    'kr ' + total.toFixed(2).replace('.', ',')
                );
            }
            
            // Focus on first field
            $('#Variant_Color').focus();
        });
        
        function selectSize(value, text) {
            $('#Variant_SizeValueId').val(value).trigger('change');
            
            // Scroll to form
            $('html, body').animate({
                scrollTop: $('#Variant_SizeValueId').offset().top - 100
            }, 500);
        }
    </script>
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string color)
    {
        // Return white for dark colors, black for light colors
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}