@model Models.Product
@using System.Globalization
@using ApplicationUtility

@{
    ViewData["Title"] = "Delete Product";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="card shadow border-0 my-4">
    <div class="card-header bg-danger bg-gradient py-3">
        <div class="text-center">
            <h2 class="text-white">
                <i class="bi bi-exclamation-triangle-fill"></i> Delete Product
            </h2>
        </div>
    </div>

    <div class="card-body p-4">
        <h4 class="text-danger mb-4">Are you sure you want to delete this product?</h4>

        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i> @TempData["error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row">
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">Brand</dt>
                    <dd class="col-sm-9">@Model.Brand</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3">Category</dt>
                    <dd class="col-sm-9">
                        @(Model.Category?.Name ?? "N/A")
                        @if (Model.Category?.DefaultSizeSystem != null)
                        {
                            <br />
                            <span class="badge bg-info mt-1">
                                <i class="bi @(Model.Category.DefaultSizeSystem.IconClass ?? "bi-tag")"></i>
                                @Model.Category.DefaultSizeSystem.Name (@Model.Category.DefaultSizeSystem.SizeType)
                            </span>
                            <br />
                            <small class="text-muted">@Model.Category.DefaultSizeSystem.Description</small>
                        }
                    </dd>

                    <dt class="col-sm-3">Variants Count</dt>
                    <dd class="col-sm-9">
                        @if (Model.Variants != null && Model.Variants.Any())
                        {
                            <span class="badge bg-warning text-dark">@Model.Variants.Count variant(s)</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No variants</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-3">Total Value</dt>
                    <dd class="col-sm-9">
                        @if (Model.Variants != null && Model.Variants.Any())
                        {
                            var totalValue = Model.Variants.Sum(v => v.Price * v.Stock);
                            <strong class="text-primary">@totalValue.ToString("C", culture)</strong>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </dd>
                </dl>

                <!-- Variants List (if any) -->
                @if (Model.Variants != null && Model.Variants.Any())
                {
                    <div class="mt-4">
                        <h5 class="text-warning">
                            <i class="bi bi-list-ul"></i> Associated Variants (@Model.Variants.Count)
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Color</th>
                                        <th>Size</th>
                                        <th>Size System</th>
                                        <th>Price</th>
                                        <th>Stock</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var variant in Model.Variants.Take(5))
                                    {
                                        var variantValue = variant.Price * variant.Stock;
                                        <tr>
                                            <td>
                                                <span class="badge" style="background-color: @GetColorBadgeColor(variant.Color); color: @GetTextColor(variant.Color); padding: 0.5rem;">
                                                    <i class="bi bi-droplet me-1"></i> @variant.Color
                                                </span>
                                            </td>
                                            <td>
                                                @if (variant.SizeValue != null)
                                                {
                                                    <strong>@variant.SizeValue.DisplayText</strong>
                                                    @if (!string.IsNullOrEmpty(variant.SizeValue.Description))
                                                    {
                                                        <br />
                                                        <small class="text-muted">@variant.SizeValue.Description</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">@variant.SizeValue</span>
                                                }
                                            </td>
                                            <td>
                                                @if (variant.SizeValue?.SizeSystem != null)
                                                {
                                                    <span class="badge bg-info">
                                                        <i class="bi @(variant.SizeValue.SizeSystem.IconClass ?? "bi-tag")"></i>
                                                        @variant.SizeValue.SizeSystem.Name
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Unknown</span>
                                                }
                                            </td>
                                            <td>@variant.Price.ToString("C", culture)</td>
                                            <td>
                                                @if (variant.Stock > 10)
                                                {
                                                    <span class="badge bg-success">@variant.Stock</span>
                                                }
                                                else if (variant.Stock > 0)
                                                {
                                                    <span class="badge bg-warning text-dark">@variant.Stock</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">0</span>
                                                }
                                            </td>
                                            <td>@variantValue.ToString("C", culture)</td>
                                        </tr>
                                    }
                                    @if (Model.Variants.Count() > 5)
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">
                                                <i class="bi bi-three-dots"></i> and @(Model.Variants.Count() - 5) more variants
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="5" class="text-end"><strong>Total Value:</strong></td>
                                        <td><strong>@Model.Variants.Sum(v => v.Price * v.Stock).ToString("C", culture)</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                }

                <!-- Warning message if product has variants -->
                @if (Model.Variants != null && Model.Variants.Any())
                {
                    <div class="alert alert-warning mt-3">
                        <div class="d-flex">
                            <div class="me-3">
                                <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                            </div>
                            <div>
                                <strong>Warning:</strong> This product has <strong>@Model.Variants.Count variant(s)</strong> with a total value of
                                <strong>@Model.Variants.Sum(v => v.Price * v.Stock).ToString("C", culture)</strong>.
                                Deleting this product will permanently delete all associated variants.
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4 text-center">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="card">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Product Image</h6>
                        </div>
                        <div class="card-body">
                            <img src="@Model.ImageUrl"
                                 class="img-fluid rounded shadow"
                                 style="max-height:200px; object-fit: cover;" />
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Product Image</h6>
                        </div>
                        <div class="card-body">
                            <div class="py-4">
                                <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                                <p class="text-muted mt-2">No image available</p>
                            </div>
                        </div>
                    </div>
                }
                
                <!-- Quick Stats Card -->
                <div class="card mt-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Quick Stats</h6>
                    </div>
                    <div class="card-body text-start">
                        <p class="mb-1">
                            <i class="bi bi-tag"></i> <strong>Category:</strong> @(Model.Category?.Name ?? "N/A")
                        </p>
                        <p class="mb-1">
                            <i class="bi bi-boxes"></i> <strong>Variants:</strong> @(Model.Variants?.Count ?? 0)
                        </p>
                        <p class="mb-0">
                            <i class="bi bi-currency-exchange"></i> <strong>Total Value:</strong>
                            @(Model.Variants != null ? Model.Variants.Sum(v => v.Price * v.Stock).ToString("C", culture) : "N/A")
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />

            @if (Model.Variants != null && Model.Variants.Any())
            {
                <div class="alert alert-warning mb-3">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="confirmDelete" onchange="toggleDeleteButton()" />
                        <label class="form-check-label fw-bold" for="confirmDelete">
                            I understand that deleting this product will also delete all @Model.Variants.Count variant(s) with a total value of
                            @Model.Variants.Sum(v => v.Price * v.Stock).ToString("C", culture)
                        </label>
                    </div>
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" id="deleteButton" class="btn btn-danger"
                    @(Model.Variants != null && Model.Variants.Any() ? "disabled" : "")>
                    <i class="bi bi-trash"></i> Delete Product
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-product-delete.js" asp-append-version="true"></script>
}

@functions {
    public string GetColorBadgeColor(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "gray" or "grey" => "#6c757d",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string color)
    {
        // Return white for dark colors, black for light colors
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" => "#000000",
            _ => "#ffffff"
        };
    }
}