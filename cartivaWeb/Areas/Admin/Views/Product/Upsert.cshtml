@model Models.ViewModels.ProductVM

@{
    ViewData["Title"] = @Model.Product.Id == 0 ? "Create Product" : "Edit Product";
    var isNewProduct = Model.Product.Id == 0;
}

<form method="post" asp-action="Upsert" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    <input asp-for="Product.Id" hidden />
    
    <div class="row">
        <div class="col-10">
            <div class="border p-3 mt-4 row">
                <div class="col-12 pb-2">
                    <h2 class="text-primary">
                        <i class="bi @(isNewProduct ? "bi-plus-circle" : "bi-pencil-square")"></i>
                        @(isNewProduct ? "Create" : "Edit") Product
                    </h2>
                    <hr />
                </div>
                
                <div class="mb-3 col-6">
                    <label asp-for="Product.Name" class="fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-tag"></i>
                        </span>
                        <input asp-for="Product.Name" class="form-control" placeholder="Enter product name" />
                    </div>
                    <span asp-validation-for="Product.Name" class="text-danger"></span>
                </div>
                
                <div class="mb-3 col-6">
                    <label asp-for="Product.Brand" class="fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-building"></i>
                        </span>
                        <input asp-for="Product.Brand" class="form-control" placeholder="Enter brand name" />
                    </div>
                    <span asp-validation-for="Product.Brand" class="text-danger"></span>
                </div>
                
                <div class="mb-3 col-6">
                    <label asp-for="Product.CategoryId" class="fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-folder"></i>
                        </span>
                        <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-select" id="CategorySelect" data-size-system-url="@Url.Action("GetCategorySizeSystem", "Product")">
                            <option disabled selected>-- Select Category --</option>
                        </select>
                    </div>
                    <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
                    
                    <!-- Size System Info - Shows when category has a size system -->
                    <div id="sizeSystemInfo" class="mt-2" style="display: none;">
                        <div class="alert alert-info py-1 small">
                            <i class="bi bi-info-circle"></i>
                            This category uses: <strong><span id="sizeSystemName"></span></strong>
                        </div>
                    </div>
                </div>
                
                <div class="mb-3 col-6">
                    <label asp-for="Product.ImageUrl" class="fw-bold">Product Image</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-image"></i>
                        </span>
                        <input type="file" name="file" class="form-control" accept="image/*" />
                    </div>
                    <small class="text-muted">Leave empty to keep current image</small>
                </div>
                
                <div class="mb-3 col-12">
                    <label asp-for="Product.Description" class="fw-bold"></label>
                    <textarea asp-for="Product.Description" class="form-control" rows="3" placeholder="Enter product description"></textarea>
                    <span asp-validation-for="Product.Description" class="text-danger"></span>
                </div>
                
                <div class="col-12">
                    <div class="btn-group" role="group">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi @(isNewProduct ? "bi-check-circle" : "bi-save")"></i>
                            @(isNewProduct ? "Create Product" : "Update Product")
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Image Preview Column -->
        @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
        {
            <div class="col-2">
                <div class="card">
                    <div class="card-header bg-light py-2">
                        <small class="fw-bold">Current Image</small>
                    </div>
                    <div class="card-body p-2 text-center">
                        <img src="@Model.Product.ImageUrl" class="img-fluid rounded" style="max-height:120px; object-fit: cover;" />
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="col-2">
                <div class="card">
                    <div class="card-header bg-light py-2">
                        <small class="fw-bold">Image Preview</small>
                    </div>
                    <div class="card-body p-3 text-center">
                        <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                        <p class="text-muted small mt-1 mb-0">No image</p>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <!-- Variants Section -->
    @if (isNewProduct)
    {
        <div class="alert alert-info mt-3">
            <i class="bi bi-info-circle"></i>
            <strong>Note:</strong> Save the product first to add variants.
        </div>
    }
    else
    {
        <hr />
        <div class="row">
            <div class="col-6">
                <h3>
                    <i class="bi bi-boxes"></i> Product Variants
                </h3>
                @if (Model.Variants != null && Model.Variants.Any())
                {
                    <p class="text-muted">Total: <strong>@Model.Variants.Count</strong> variants</p>
                }
            </div>
            <div class="col-6 text-end">
                <a asp-action="CreateProductVariant"
                       asp-route-productId="@Model.Product.Id"
                       class="btn btn-info">
                    <i class="bi bi-plus-circle"></i> Add New Variant
                </a>
            </div>
        </div>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Color</th>
                    <th>Size</th>
                    <th>Size System</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Variants != null && Model.Variants.Any())
                {
                    @foreach (var v in Model.Variants)
                    {
                        <tr>
                            <td>
                                <span class="badge" style="background-color: @GetColorBadgeColor(v.Color); color: @GetTextColor(v.Color); padding: 0.5rem;">
                                    <i class="bi bi-droplet me-1"></i> @v.Color
                                </span>
                            </td>
                            <td>
                                @if (v.SizeValue != null)
                                {
                                    <strong>@v.SizeValue.DisplayText</strong>
                                    @if (!string.IsNullOrEmpty(v.SizeValue.Description))
                                    {
                                        <br />
                                        <small class="text-muted">
                                            <i class="bi bi-info-circle"></i> @v.SizeValue.Description
                                        </small>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No size</span>
                                }
                            </td>
                            <td>
                                @if (v.SizeValue?.SizeSystem != null)
                                {
                                    <span class="badge bg-info">
                                        <i class="bi @(v.SizeValue.SizeSystem.IconClass ?? "bi-tag")"></i>
                                        @v.SizeValue.SizeSystem.Name
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Accessory</span>
                                }
                            </td>
                            <td>@v.Price.ToString("C")</td>
                            <td>
                                @if (v.Stock > 10)
                                {
                                    <span class="badge bg-success">@v.Stock</span>
                                }
                                else if (v.Stock > 0)
                                {
                                    <span class="badge bg-warning text-dark">@v.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Out of Stock</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="EditProductVariant"
                                           asp-route-id="@v.Id"
                                           class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="DeleteProductVariant"
                                           asp-route-id="@v.Id"
                                           class="btn btn-danger btn-sm btn-swal-confirm"
                                           data-swal-title="Delete this variant?"
                                           data-swal-text="This action cannot be undone.">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-box" style="font-size: 2rem;"></i>
                            <p class="mt-2">No variants added yet. Click "Add New Variant" to create one.</p>
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.Variants != null && Model.Variants.Any())
            {
                <tfoot class="table-light">
                    <tr>
                        <td colspan="3" class="text-end"><strong>Total Value:</strong></td>
                        <td colspan="3"><strong>@Model.Variants.Sum(v => v.Price * v.Stock).ToString("C")</strong></td>
                    </tr>
                </tfoot>
            }
        </table>
    }
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-product-upsert.js" asp-append-version="true"></script>
}

@functions {
    public string GetColorBadgeColor(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string color)
    {
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}