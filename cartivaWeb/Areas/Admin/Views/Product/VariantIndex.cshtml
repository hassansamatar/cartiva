@model IEnumerable<Models.ViewModels.ProductVariant>

@{
    ViewData["Title"] = "Product Variants";
    var productId = ViewBag.ProductId;
    var productName = ViewBag.ProductName ?? "Product";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Variants for @productName</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="VariantCreate" asp-route-productId="@productId" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Variant
            </a>
            <a asp-action="Upsert" asp-route-id="@productId" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Product
            </a>
        </div>
    </div>
    <br />

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Color</th>
                    <th>Size</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var variant in Model)
                {
                    <tr>
                        <td>@variant.Color</td>
                        <td>@variant.Size</td>
                        <td>@variant.Price.ToString("C")</td>
                        <td>@variant.Stock</td>
                        <td>
                            <a asp-action="VariantEdit" asp-route-id="@variant.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="VariantDelete" asp-route-id="@variant.Id" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete this variant?')">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            No variants found for this product. Click "Add New Variant" to create one.
        </div>
    }
</div>