@using System.Globalization
@using ApplicationUtility
@model IEnumerable<ProductVariant>

@{
    ViewData["Title"] = "Product Variants";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    var productId = ViewBag.ProductId;
    var productName = ViewBag.ProductName ?? "Product";
    var categoryName = ViewBag.CategoryName ?? "";
    
    // Determine category type from the size system (now database-driven)
    var hasSizeSystem = ViewBag.SizeSystem != null;
    var sizeSystemName = ViewBag.SizeSystem?.Name ?? "";
    var sizeSystemType = ViewBag.SizeSystem?.SizeType ?? "";
    var sizeSystemIcon = ViewBag.SizeSystem?.IconClass ?? "bi-tag";
    
    var isKidsCategory = sizeSystemType.Equals("Kid", StringComparison.OrdinalIgnoreCase);
    var isSuitCategory = sizeSystemType.Equals("Suit", StringComparison.OrdinalIgnoreCase);
    var isShoeCategory = sizeSystemType.Equals("Shoe", StringComparison.OrdinalIgnoreCase);
    var isAccessoryCategory = !hasSizeSystem;
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">
                <i class="bi @(sizeSystemIcon) me-2"></i>
                Variants for @productName
            </h2>
            <p class="text-muted">
                <i class="bi bi-folder me-1"></i> Category: @categoryName
                @if (hasSizeSystem)
                {
                    <span class="badge bg-info ms-2">
                        <i class="bi @(sizeSystemIcon) me-1"></i> @sizeSystemName
                    </span>
                    <small class="d-block text-muted mt-1">
                        <i class="bi bi-info-circle"></i> @ViewBag.SizeSystem?.Description
                    </small>
                }
                else
                {
                    <span class="badge bg-secondary ms-2">
                        <i class="bi bi-dash"></i> No size system
                    </span>
                    <small class="d-block text-muted mt-1">
                        <i class="bi bi-info-circle"></i> This product does not require size selection
                    </small>
                }
            </p>
        </div>
        <div class="col-6 text-end">
            <div class="btn-group" role="group">
                <a asp-controller="Product"
                       asp-action="CreateProductVariant"
                       asp-route-productId="@productId"
                       class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i>
                    Add New Variant
                    @if (hasSizeSystem)
                    {
                        <text>(@sizeSystemName)</text>
                    }
                    else
                    {
                        <text>(Accessory)</text>
                    }
                </a>
                
                <a asp-controller="Product"
                       asp-action="Upsert"
                       asp-route-id="@productId"
                       class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Product
                </a>
            </div>
        </div>
    </div>
    <br />

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Color</th>
                    <th>Size</th>
                    <th>Size System</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var variant in Model)
                {
                    <tr>
                        <td>
                            <span class="badge" style="background-color: @(GetColorCode(variant.Color)); color: @(GetTextColor(variant.Color)); padding: 0.5rem 0.8rem;">
                                <i class="bi bi-droplet me-1"></i> @variant.Color
                            </span>
                        </td>
                        <td>
                            @if (variant.SizeValue != null)
                            {
                                <strong>@variant.SizeValue.DisplayText</strong>
                                @if (!string.IsNullOrEmpty(variant.SizeValue.Description))
                                {
                                    <br />
                                    <small class="text-muted">
                                        <i class="bi bi-info-circle"></i> @variant.SizeValue.Description
                                    </small>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-dash"></i> No size required
                                </span>
                            }
                        </td>
                        <td>
                            @if (variant.SizeValue?.SizeSystem != null)
                            {
                                <div class="d-flex align-items-center">
                                    <i class="bi @(variant.SizeValue.SizeSystem.IconClass ?? "bi-tag") me-2 text-info"></i>
                                    <span class="badge bg-info">@variant.SizeValue.SizeSystem.Name</span>
                                    <small class="ms-1 text-muted">(@variant.SizeValue.SizeSystem.SizeType)</small>
                                </div>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-dash"></i> Accessory
                                </span>
                            }
                        </td>
                        <td>
                            <strong>@variant.Price.ToString("C", culture)</strong>
                        </td>
                        <td>
                            @if (variant.Stock > 10)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> @variant.Stock in stock
                                </span>
                            }
                            else if (variant.Stock > 0)
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-exclamation-triangle"></i> @variant.Stock left (low)
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle"></i> Out of stock
                                </span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-controller="Product"
                                       asp-action="EditProductVariant"
                                       asp-route-id="@variant.Id"
                                       class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-controller="Product"
                                       asp-action="DeleteProductVariant"
                                       asp-route-id="@variant.Id"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this variant?')">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="4" class="text-end"><strong>Total Variants:</strong></td>
                    <td><strong>@Model.Count()</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi @(hasSizeSystem ? "bi-box" : "bi-gem")" style="font-size: 4rem;"></i>
            <h5 class="mt-3">No variants found for this product</h5>
            <p>
                Click the "Add New Variant" button to create your first variant.
            </p>
            @if (hasSizeSystem)
            {
                <div class="mt-3 p-3 bg-light rounded d-inline-block">
                    <i class="bi @(sizeSystemIcon) me-2 text-info"></i>
                    <strong>@sizeSystemName</strong>
                    <p class="small text-muted mt-2 mb-0">@ViewBag.SizeSystem?.Description</p>
                </div>
            }
            else
            {
                <div class="mt-3 p-3 bg-light rounded d-inline-block">
                    <i class="bi bi-gem me-2 text-secondary"></i>
                    <strong>Accessory Product</strong>
                    <p class="small text-muted mt-2 mb-0">This product does not use sizes. Variants will only differ by color.</p>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // Log page info
        console.log('Variant page loaded - size system: @(sizeSystemName) (@(sizeSystemType))');
        
        // Optional: Add tooltips if needed
        document.addEventListener('DOMContentLoaded', function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#212529",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "pink" => "#d63384",
            "gray" or "grey" => "#6c757d",
            "tan" => "#d2b48c",
            _ => "#6c757d"
        };
    }
    
    public string GetTextColor(string color)
    {
        // Return white for dark colors, black for light colors
        return color?.ToLower() switch
        {
            "white" or "yellow" or "lightgray" or "lightgrey" or "tan" => "#000000",
            _ => "#ffffff"
        };
    }
}