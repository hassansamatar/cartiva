@using System.Globalization
@model IEnumerable<Models.ProductVariant>

@{
    ViewData["Title"] = "Product Variants";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    var productId = ViewBag.ProductId;
    var productName = ViewBag.ProductName ?? "Product";
    var categoryName = ViewBag.CategoryName ?? "";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Variants for @productName</h2>
            <p class="text-muted">Category: @categoryName</p>
        </div>
        <div class="col-6 text-end">
            <div class="btn-group" role="group">
                @if (categoryName.Contains("Kids", StringComparison.OrdinalIgnoreCase) ||
                     categoryName.Contains("Children", StringComparison.OrdinalIgnoreCase))
                {
                    <!-- Only show Kids button for kids categories -->
                    <a asp-action="CreateProductVariant"
                           asp-route-productId="@productId"
                           asp-route-sizeType="Regular"
                           class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add Kid Variant (2-5 Years)
                    </a>
                }
                else
                {
                    <!-- Dropdown for Adult variants -->
                    <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-plus-circle"></i> Add Adult Variant
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-action="CreateProductVariant"
                                   asp-route-productId="@productId"
                                   asp-route-sizeType="Regular">
                                <i class="bi bi-person"></i> Regular (S, M, L, XL, XXL)
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-action="CreateProductVariant"
                                   asp-route-productId="@productId"
                                   asp-route-sizeType="Suit">
                                <i class="bi bi-person-badge"></i> Suit (36, 38, 40, 42, 44, 46)
                            </a>
                        </li>
                    </ul>
                }
                
                <a asp-action="Upsert" asp-route-id="@productId" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Product
                </a>
            </div>
        </div>
    </div>
    <br />

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Color</th>
                    <th>Size</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var variant in Model)
                {
                    <tr>
                        <td>
                            <span class="badge" style="background-color: @(GetColorCode(variant.Color)); color: white;">
                                @variant.Color
                            </span>
                        </td>
                        <td>
                            @if (categoryName.Contains("Kids", StringComparison.OrdinalIgnoreCase) ||
                                 categoryName.Contains("Children", StringComparison.OrdinalIgnoreCase))
                            {
                                <!-- Display kid sizes with "Years" suffix -->
                                <span>@variant.Size Years</span>
                            }
                            else
                            {
                                <!-- Display adult sizes as is -->
                                <span>@variant.Size</span>
                            }
                        </td>
                        <td>@variant.Price.ToString("C", culture)</td>
                        <td>
                            @if (variant.Stock > 0)
                            {
                                <span class="badge bg-success">@variant.Stock in stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Out of stock</span>
                            }
                        </td>
                        <td>
                            <a asp-action="EditProductVariant" asp-route-id="@variant.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="DeleteProductVariant" asp-route-id="@variant.Id" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete this variant?')">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No variants found for this product. Click "Add New Variant" to create one.
        </div>
    }
</div>

@section Scripts {
    <script>
        // Initialize Bootstrap dropdowns
        var dropdownElementList = [].slice.call(document.querySelectorAll('.dropdown-toggle'))
        var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
            return new bootstrap.Dropdown(dropdownToggleEl)
        });
    </script>
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#000000",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            _ => "#6c757d"
        };
    }
}