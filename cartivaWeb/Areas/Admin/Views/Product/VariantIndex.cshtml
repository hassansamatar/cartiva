@using System.Globalization
@model IEnumerable<Models.ProductVariant>

@{
    ViewData["Title"] = "Product Variants";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    var productId = ViewBag.ProductId;
    var productName = ViewBag.ProductName ?? "Product";
    var categoryName = ViewBag.CategoryName ?? "";
    
    // Determine category type
    var isKidsCategory = categoryName.Contains("Kids", StringComparison.OrdinalIgnoreCase) ||
                        categoryName.Contains("Children", StringComparison.OrdinalIgnoreCase);
    
    var isSuitCategory = categoryName.Contains("Suit", StringComparison.OrdinalIgnoreCase) ||
                         categoryName.Contains("Formal", StringComparison.OrdinalIgnoreCase) ||
                         categoryName.Contains("Blazer", StringComparison.OrdinalIgnoreCase) ||
                         categoryName.Contains("Dress Shirt", StringComparison.OrdinalIgnoreCase);
    
    var isAdultRegularCategory = !isKidsCategory && !isSuitCategory;
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Variants for @productName</h2>
            <p class="text-muted">Category: @categoryName</p>
        </div>
        <div class="col-6 text-end">
            <div class="btn-group" role="group">
                @if (isKidsCategory)
                {
                    <!-- KIDS CATEGORY - Direct button -->
                    <a asp-action="CreateProductVariant"
                           asp-route-productId="@productId"
                           asp-route-sizeType="Kids"
                           class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add Kid Variant 
                    </a>
                }
                else if (isSuitCategory)
                {
                    <!-- SUIT CATEGORY - Direct button with number sizes -->
                    <a asp-action="CreateProductVariant"
                           asp-route-productId="@productId"
                           asp-route-sizeType="Suit"
                           class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add Suit Variant
                    </a>
                }
                else
                {
                    <!-- REGULAR ADULT CATEGORY - Direct button with letter sizes -->
                    <a asp-action="CreateProductVariant"
                           asp-route-productId="@productId"
                           asp-route-sizeType="Regular"
                           class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add Adult Variant 
                    </a>
                }
                
                <a asp-action="Upsert" asp-route-id="@productId" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Product
                </a>
            </div>
        </div>
    </div>
    <br />

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Color</th>
                    <th>Size</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var variant in Model)
                {
                    <tr>
                        <td>
                            <span class="badge" style="background-color: @(GetColorCode(variant.Color)); color: white;">
                                @variant.Color
                            </span>
                        </td>
                        <td>
                            @if (isKidsCategory)
                            {
                                <!-- Kid sizes - numbers with "Years" -->
                                <span>@variant.Size </span>
                            }
                            else if (isSuitCategory)
                            {
                                <!-- SUIT SIZES - JUST NUMBERS (no prefix) -->
                                <span>@variant.Size</span>
                            }
                            else
                            {
                                <!-- Regular adult sizes - letters as-is -->
                                <span>@variant.Size</span>
                            }
                        </td>
                        <td>@variant.Price.ToString("C", culture)</td>
                        <td>
                            @if (variant.Stock > 0)
                            {
                                <span class="badge bg-success">@variant.Stock in stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Out of stock</span>
                            }
                        </td>
                        <td>
                            <a asp-action="EditProductVariant" asp-route-id="@variant.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="DeleteProductVariant" asp-route-id="@variant.Id" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete this variant?')">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No variants found for this product. Click
            "@if (isKidsCategory)
            {
                <text>Add Kid Variant</text>
            }
             else if (isSuitCategory)
            {
                <text>Add Suit Variant</text>
            }
            else
            {
                <text>Add Regular Variant</text>
            }
            "
            to create one.
        </div>
    }
</div>

@section Scripts {
    <script>
        console.log('Variant page loaded - category type: @(isKidsCategory ? "Kids" : isSuitCategory ? "Suit" : "Regular")');
    </script>
}

@functions {
    public string GetColorCode(string color)
    {
        return color?.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "black" => "#000000",
            "white" => "#ffffff",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "orange" => "#fd7e14",
            "brown" => "#795548",
            "navy" => "#001f3f",
            "gray" or "grey" => "#6c757d",
            _ => "#6c757d"
        };
    }
}