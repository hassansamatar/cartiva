@model Models.Promotion

@{
    ViewData["Title"] = Model.Id == 0 ? "Create Promotion" : "Edit Promotion";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-7 col-md-9">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-dark text-white text-center py-3">
                <h3 class="mb-0">
                    <i class="bi bi-gift me-2"></i>
                    @(Model.Id == 0 ? "Create Promotion" : "Edit Promotion")
                </h3>
            </div>
            <div class="card-body p-4">
                <form asp-action="Upsert" method="post" class="row g-3">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <!-- Name -->
                    <div class="form-floating col-12">
                        <input asp-for="Name" class="form-control" placeholder="Promotion Name" />
                        <label asp-for="Name"></label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="form-floating col-12">
                        <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 80px"></textarea>
                        <label asp-for="Description"></label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <!-- Category -->
                    <div class="form-floating col-12">
                        <select asp-for="CategoryId" asp-items="@ViewBag.CategoryList" class="form-select">
                            <option value="">-- Select Category --</option>
                        </select>
                        <label asp-for="CategoryId"></label>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <!-- Buy / Get -->
                    <div class="col-md-6">
                        <div class="card bg-light border-0 p-3 text-center">
                            <label asp-for="BuyQuantity" class="form-label fw-bold text-primary">Buy</label>
                            <input asp-for="BuyQuantity" type="number" class="form-control form-control-lg text-center" min="2" max="10" />
                            <span asp-validation-for="BuyQuantity" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-success bg-opacity-10 border-0 p-3 text-center">
                            <label asp-for="GetQuantity" class="form-label fw-bold text-success">Get Free</label>
                            <input asp-for="GetQuantity" type="number" class="form-control form-control-lg text-center" min="1" max="10" />
                            <span asp-validation-for="GetQuantity" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Preview -->
                    <div class="col-12">
                        <div class="alert alert-success text-center fs-5" id="promoPreview">
                            <i class="bi bi-gift me-2"></i>
                            <strong>Buy <span id="previewBuy">@Model.BuyQuantity</span>, Get <span id="previewGet">@Model.GetQuantity</span> Free!</strong>
                        </div>
                    </div>

                    <!-- Dates -->
                    <div class="form-floating col-md-6">
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <label asp-for="StartDate"></label>
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-md-6">
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <label asp-for="EndDate"></label>
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>

                    <!-- Active -->
                    <div class="form-check form-switch col-12 mt-3">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>

                    <!-- Buttons -->
                    <div class="col-12 mt-3 d-flex justify-content-between">
                        <button type="submit" class="btn btn-dark btn-lg px-4">
                            <i class="bi bi-check-circle me-1"></i>
                            @(Model.Id == 0 ? "Create" : "Update")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('[name="BuyQuantity"]').addEventListener('input', updatePreview);
        document.querySelector('[name="GetQuantity"]').addEventListener('input', updatePreview);
        function updatePreview() {
            document.getElementById('previewBuy').textContent = document.querySelector('[name="BuyQuantity"]').value;
            document.getElementById('previewGet').textContent = document.querySelector('[name="GetQuantity"]').value;
        }
    </script>
}
