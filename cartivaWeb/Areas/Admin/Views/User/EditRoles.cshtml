@using ApplicationUtility
@using CartivaWeb.Areas.Admin.Controllers
@using Models.ViewModels
@model EditRolesViewModel

@{
    ViewData["Title"] = "Edit User Roles";
}

<div class="container mt-4">
    <h2>Edit Roles</h2>

    <div class="card mb-3">
        <div class="card-header bg-primary text-white">
            User Information
        </div>
        <div class="card-body">
            <p><strong>Name:</strong> @Model.UserName</p>
            <p><strong>Email:</strong> @Model.UserEmail</p>
            <p>
                <strong>Current Role:</strong>
                <span class="badge bg-secondary">@Model.SelectedRole</span>
            </p>
        </div>
    </div>

    <form asp-action="EditRoles" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />

        <!-- Role Selection -->
        <div class="mb-3">
            <label class="form-label">Assign New Role</label>
            <select name="SelectedRole" id="roleSelect" class="form-select" data-company-role="@SD.Role_Company">
                <option value="">-- None --</option>
                @foreach (var role in Model.AvailableRoles)
                {
                    if (role == Model.SelectedRole)
                    {
                        <option value="@role" selected>@role</option>
                    }
                    else
                    {
                        <option value="@role">@role</option>
                    }
                }
            </select>
        </div>

        <!-- Company Selection -->
        <div class="mb-3" id="companyDiv" style="display:@(Model.SelectedRole == SD.Role_Company ? "block" : "none")">
            <label class="form-label">Assign Company</label>
            <select name="CompanyId" class="form-select">
                <option value="">-- Select Company --</option>
                @foreach (var company in Model.Companies)
                {
                    if (company.Id == Model.CompanyId)
                    {
                        <option value="@company.Id" selected>@company.Name</option>
                    }
                    else
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                }
            </select>
        </div>

        <!-- Buttons -->
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <script src="~/js/admin-user-editroles.js" asp-append-version="true"></script>
}