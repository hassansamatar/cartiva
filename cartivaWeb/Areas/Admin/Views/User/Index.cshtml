@model List<ApplicationUser>
@using ApplicationUtility

@{
    ViewData["Title"] = "User Management";
    var userRoles = ViewBag.UserRoles as Dictionary<string, string>;
    var companyUsers = ViewBag.CompanyUsers as Dictionary<int, List<ApplicationUser>>;
}

<div class="container mt-4">

    ```
    @Html.AntiForgeryToken()

    <div class="card shadow-sm border-0">

        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="bi bi-people"></i> User Management
            </h4>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Role</th>
                            <th>Company</th>
                            <th>Status</th>
                            <th class="text-center" style="width:260px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var user in Model)
                        {
                            var role = userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : "None";
                            var rowClass = user.IsInactive ? "table-danger" : "";

                            <tr class="@rowClass">

                                <td>@user.Email</td>

                                <td>@user.Name</td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @role
                                    </span>
                                </td>

                                <td>
                                    @if (user.Company != null)
                                    {
                                        var colleagues = companyUsers != null && companyUsers.ContainsKey(user.CompanyId!.Value)
                                            ? companyUsers[user.CompanyId.Value].Where(u => u.Id != user.Id).ToList()
                                            : new List<ApplicationUser>();

                                        <div>
                                            <span class="fw-bold">
                                                <i class="bi bi-building me-1"></i>@user.Company.Name
                                            </span>
                                        </div>
                                        if (colleagues.Any())
                                        {
                                            <details class="mt-1">
                                                <summary class="text-muted small" style="cursor:pointer;">
                                                    <i class="bi bi-people"></i> @colleagues.Count other member@(colleagues.Count > 1 ? "s" : "")
                                                </summary>
                                                <ul class="list-unstyled mb-0 mt-1 ms-2">
                                                    @foreach (var c in colleagues)
                                                    {
                                                        <li class="small text-muted">
                                                            <i class="bi bi-person me-1"></i>@(c.Name ?? c.Email)
                                                            @if (!string.IsNullOrEmpty(c.Name))
                                                            {
                                                                <span class="text-muted opacity-75">(@c.Email)</span>
                                                            }
                                                        </li>
                                                    }
                                                </ul>
                                            </details>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            <i class="bi bi-dash"></i> None
                                        </span>
                                    }
                                </td>

                                <td>
                                    @if (!user.IsInactive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-x-circle"></i> Inactive
                                        </span>
                                    }
                                </td>

                                <td class="text-center">

                                    <div class="d-flex justify-content-center gap-2">

                                        <a asp-action="EditRoles"
                                               asp-route-id="@user.Id"
                                               class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-shield-lock"></i> Roles
                                        </a>

                                        @if (!user.IsInactive)
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="deactivateUser('@user.Id')">
                                                <i class="bi bi-person-x"></i> Deactivate
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-success"
                                                    onclick="activateUser('@user.Id')">
                                                <i class="bi bi-person-check"></i> Activate
                                            </button>
                                        }

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
    ```

</div>

@section Scripts
{
    <input type="hidden" id="deactivateUrl" value="@Url.Action("Deactivate", "User", new { area = "Admin" })" />
    <input type="hidden" id="activateUrl" value="@Url.Action("Activate", "User", new { area = "Admin" })" />
    <script src="~/js/admin-user-index.js" asp-append-version="true"></script>
}
