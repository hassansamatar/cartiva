@model IEnumerable<Company>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<div class="card shadow border-0 mt-4">

    <!-- Card Header -->
    <div class="card-header bg-dark text-white py-3">
        <div class="row">
            <div class="col-6">
                <h4 class="mb-0">
                    <i class="bi bi-building me-2"></i> Company List
                </h4>
            </div>

            <div class="col-6 text-end">
                <a asp-area="Admin"
                       asp-controller="Company"
                       asp-action="Upsert"
                       class="btn btn-light">
                    <i class="bi bi-plus-circle me-1"></i> Create Company
                </a>
            </div>
        </div>
    </div>

    <!-- Card Body -->
    <div class="card-body">

        <table id="tblCompany" class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>City</th>
                    <th>State</th>
                    <th>Postal Code</th>
                    <th>Phone</th>
                    <th>Email Address</th>
                    <th style="width:150px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var company in Model)
                {
                    <tr>
                        <td>@company.Name</td>
                        <td>@company.City</td>
                        <td>@company.State</td>
                        <td>@company.PostalCode</td>
                        <td>@company.PhoneNumber</td>
                        <td>@company.Email</td>
                        <td>
                            <div class="text-center">
                                <a asp-area="Admin" asp-controller="Company" asp-action="Upsert" asp-route-id="@company.Id" class="btn btn-sm btn-dark me-2">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <a asp-area="Admin" asp-controller="Company" asp-action="Delete" asp-route-id="@company.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    
    <script>
        $(document).ready(function () {
        $('#tblCompany').DataTable({
        "paging": true,
        "searching": true,
        "ordering": true,
        "lengthChange": true,
        "pageLength": 10
        });
        });
    </script>
}