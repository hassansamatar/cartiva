@using Models.ViewModels
@model IEnumerable<CompanyListVM>

@{
    ViewData["Title"] = "Company List";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<div class="card shadow border-0 mt-4">

    <!-- Card Header -->
    <div class="card-header bg-dark text-white py-3">
        <div class="row">
            <div class="col-6">
                <h4 class="mb-0">
                    <i class="bi bi-building me-2"></i> Company List
                </h4>
            </div>

            <div class="col-6 text-end">
                <a asp-area="Admin"
                       asp-controller="Company"
                       asp-action="Upsert"
                       class="btn btn-light">
                    <i class="bi bi-plus-circle me-1"></i> Create Company
                </a>
            </div>
        </div>
    </div>

    <!-- Card Body -->
    <div class="card-body">

        <table id="tblCompany" class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Address, Postal Code</th>
                    <th>City</th>
                    <th>Phone</th>
                    <th>Contact Person</th>
                    <th>Payment Status</th>
                    <th>Status</th> <!-- New column -->
                    <th style="width:150px">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Company.Name</td>
                        <td>@item.Company.StreetAddress, @item.Company.PostalCode</td>
                        <td>@item.Company.City</td>
                        <td>@item.Company.PhoneNumber</td>
                        <td>@item.ContactPerson</td>

                        <td>
                            @if (item.PaymentStatus == "Paid")
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else if (item.PaymentStatus == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                            else if (item.PaymentStatus == "Overdue")
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No Orders</span>
                            }
                        </td>

                        <td>
                            @if (item.Company.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>

                        <td>
                            <div class="text-center">
                                <a asp-area="Admin"
                                       asp-controller="Company"
                                       asp-action="Upsert"
                                       asp-route-id="@item.Company.Id"
                                       class="btn btn-sm btn-dark me-2">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <a asp-area="Admin"
                                       asp-controller="Company"
                                       asp-action="Delete"
                                       asp-route-id="@item.Company.Id"
                                       class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
        $('#tblCompany').DataTable({
        paging: true,
        searching: true,
        ordering: true,
        lengthChange: true,
        pageLength: 10,
        columnDefs: [
        { orderable: false, targets: 7 } // Actions column index (last column)
        ]
        });
        });
    </script>
}