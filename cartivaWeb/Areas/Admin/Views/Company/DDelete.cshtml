@model Company

@{
    ViewData["Title"] = "Delete Company";
}

<div class="card shadow border-0 my-4">

    <!-- Card Header -->
    <div class="card-header bg-danger bg-gradient py-3">
        <div class="text-center">
            <h2 class="text-white">Delete Company</h2>
        </div>
    </div>

    <!-- Card Body -->
    <div class="card-body p-4">

        <h4 class="text-danger mb-4">Are you sure you want to delete this company?</h4>

        <div class="row">

            <div class="col-md-8">

                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">Street Address</dt>
                    <dd class="col-sm-9">@Model.StreetAddress</dd>

                    <dt class="col-sm-3">City</dt>
                    <dd class="col-sm-9">@Model.City</dd>

                    <dt class="col-sm-3">State</dt>
                    <dd class="col-sm-9">@Model.State</dd>

                    <dt class="col-sm-3">Postal Code</dt>
                    <dd class="col-sm-9">@Model.PostalCode</dd>

                    <dt class="col-sm-3">Phone Number</dt>
                    <dd class="col-sm-9">@Model.PhoneNumber</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>
                </dl>

            </div>

        </div>

        <!-- Form -->
        <form asp-action="DeletePOST" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">
                Delete
            </button>

            <a asp-area="Admin" asp-controller="Company" asp-action="Index" class="btn btn-secondary ms-2">
                Back to List
            </a>
        </form>

    </div>

</div>