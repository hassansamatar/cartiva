@model Company
@{
    ViewData["Title"] = Model.Id != 0 ? "Update Company" : "Create Company";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-7 col-md-9">

        <div class="card shadow border-0 rounded-3">

            <!-- Header -->
            <div class="card-header bg-dark text-white text-center py-3">
                <h3 class="mb-0">
                    <i class="bi bi-building me-2"></i>
                    @(Model.Id != 0 ? "Update Company" : "Create Company")
                </h3>
            </div>

            <!-- Body -->
            <div class="card-body p-4">

                <form asp-action="Upsert" method="post" id="companyForm" class="row g-3">

                    <input asp-for="Id" type="hidden" />

                    <p class="text-center text-muted mb-3">
                        @(Model.Id != 0 ? "Update company information" : "Register a new company")
                    </p>

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Company Name -->
                    <div class="form-floating col-md-12">
                        <input asp-for="Name" class="form-control" placeholder="Company Name" />
                        <label asp-for="Name">Company Name</label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Street -->
                    <div class="form-floating col-md-12">
                        <input asp-for="StreetAddress" id="street" class="form-control" placeholder="Street Address" />
                        <label asp-for="StreetAddress">Street Address</label>
                        <span asp-validation-for="StreetAddress" class="text-danger"></span>
                    </div>

                    <!-- Address Suggestions -->
                    <div id="addressSuggestions" class="list-group col-md-12 mb-2"></div>

                    <!-- City -->
                    <div class="form-floating col-md-6">
                        <input asp-for="City" id="city" class="form-control" readonly />
                        <label asp-for="City">City</label>
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>

                    <!-- State -->
                    <div class="form-floating col-md-6">
                        <input asp-for="State" id="state" class="form-control" readonly />
                        <label asp-for="State">State</label>
                        <span asp-validation-for="State" class="text-danger"></span>
                    </div>

                    <!-- Postal -->
                    <div class="form-floating col-md-6">
                        <input asp-for="PostalCode" id="postalCode" class="form-control" readonly />
                        <label asp-for="PostalCode">Postal Code</label>
                        <span asp-validation-for="PostalCode" class="text-danger"></span>
                    </div>

                    <!-- Phone -->
                    <div class="form-floating col-md-6">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                        <label asp-for="PhoneNumber">Phone Number</label>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <!-- Active / Inactive -->
                    <div class="form-check form-switch col-md-12 mt-3">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </label>
                    </div>

                    <!-- Buttons -->
                    <div class="col-12 mt-3 d-flex justify-content-between">
                        <button type="submit" class="btn btn-dark btn-lg px-4">
                            @(Model.Id != 0 ? "Update Company" : "Create Company")
                        </button>

                        <a asp-area="Admin"
                               asp-controller="Company"
                               asp-action="Index"
                               class="btn btn-outline-secondary btn-lg">
                            Back to List
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/address_autocomlete.js"></script>
    <script src="~/js/admin-company-upsert.js" asp-append-version="true"></script>
}