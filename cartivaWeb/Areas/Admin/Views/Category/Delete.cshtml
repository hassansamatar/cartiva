@model Category
@{
    ViewData["Title"] = "Delete Category";
}

<div class="container">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-danger">
                <i class="bi bi-exclamation-triangle"></i> Delete Category
            </h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            @if (ViewBag.HasProducts != null && ViewBag.HasProducts)
            {
                <div class="alert alert-danger mb-4">
                    <div class="d-flex">
                        <div class="me-3">
                            <i class="bi bi-exclamation-octagon-fill fs-1"></i>
                        </div>
                        <div>
                            <h5 class="alert-heading">Cannot Delete Category</h5>
                            <p class="mb-0">
                                This category has products assigned to it.
                                Please reassign or delete the products first before deleting this category.
                            </p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-4">
                    <div class="d-flex">
                        <div class="me-3">
                            <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                        </div>
                        <div>
                            <h5 class="alert-heading">Are you sure?</h5>
                            <p class="mb-0">
                                You are about to delete this category. This action cannot be undone.
                            </p>
                        </div>
                    </div>
                </div>
            }

            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Category Details</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Category ID</dt>
                        <dd class="col-sm-9">@Model.Id</dd>

                        <dt class="col-sm-3">Category Name</dt>
                        <dd class="col-sm-9">
                            <i class="bi bi-folder me-2 text-primary"></i>
                            @Model.Name
                        </dd>

                        <dt class="col-sm-3">Default Size System</dt>
                        <dd class="col-sm-9">
                            @if (Model.DefaultSizeSystem != null)
                            {
                                <div class="d-flex align-items-center">
                                    <i class="bi @(Model.DefaultSizeSystem.IconClass ?? "bi-tag") me-2 text-info"></i>
                                    <span class="badge bg-info me-1">
                                        @Model.DefaultSizeSystem.Name
                                    </span>
                                    <span class="badge bg-light text-dark">@Model.DefaultSizeSystem.SizeType</span>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.DefaultSizeSystem.Description))
                                {
                                    <small class="text-muted d-block mt-1">
                                        <i class="bi bi-info-circle"></i> @Model.DefaultSizeSystem.Description
                                    </small>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-dash"></i> No default size system
                                </span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            @if (ViewBag.HasProducts != null && ViewBag.HasProducts)
            {
                <div class="mt-4">
                    <a asp-controller="Category" asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            }
            else
            {
                <form asp-controller="Category" asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3 d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Confirm Delete
                        </button>
                        <a asp-controller="Category" asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            }
        </div>

        <!-- Summary Card -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Summary
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Category:</strong><br />
                        <span class="badge bg-primary">@Model.Name</span>
                    </p>
                    
                    <p class="mb-2">
                        <strong>Status:</strong><br />
                        @if (ViewBag.HasProducts != null && ViewBag.HasProducts)
                        {
                            <span class="badge bg-danger">
                                <i class="bi bi-exclamation-circle"></i> In Use (@ViewBag.ProductCount products)
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i> Not in use
                            </span>
                        }
                    </p>
                    
                    <hr />
                    
                    <p class="text-muted small mb-0">
                        <i class="bi bi-clock"></i>
                        @if (ViewBag.HasProducts != null && ViewBag.HasProducts)
                        {
                            <span>This category cannot be deleted because it has associated products.</span>
                        }
                        else
                        {
                            <span>Deleted categories cannot be recovered.</span>
                        }
                    </p>
                </div>
            </div>
            
            <!-- Related Products Card (if any) -->
            @if (ViewBag.HasProducts != null && ViewBag.HasProducts && ViewBag.ProductCount > 0)
            {
                <div class="card mt-3">
                    <div class="card-header bg-warning text-dark">
                        <h6 class="mb-0">
                            <i class="bi bi-box"></i> Affected Products
                        </h6>
                    </div>
                    <div class="card-body small">
                        <p class="mb-2">
                            This category is used by <strong>@ViewBag.ProductCount product(s)</strong>:
                        </p>
                        <ul class="list-unstyled">
                            @if (ViewBag.ProductList != null)
                            {
                                @foreach (var product in ViewBag.ProductList)
                                {
                                    <li class="mb-1">
                                        <i class="bi bi-dot text-primary"></i> @product.Name
                                    </li>
                                }
                            }
                        </ul>
                        <p class="text-muted mt-2 mb-0">
                            <i class="bi bi-lightbulb"></i>
                            <em>Reassign these products to another category before deleting.</em>
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Add confirmation for delete
        document.querySelector('form')?.addEventListener('submit', function(e) {
            if (!confirm('Are you absolutely sure you want to delete this category?')) {
                e.preventDefault();
            }
        });
    </script>
}