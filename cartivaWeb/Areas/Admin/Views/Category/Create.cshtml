@model Category
@{
    ViewData["Title"] = "Create Category";
}

<div class="container">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-primary">
                <i class="bi bi-plus-circle"></i> Create New Category
            </h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <form method="post" asp-controller="Category" asp-action="Create">
                <div class="border p-3 mt-4">
                    <div asp-validation-summary="All" class="text-danger"></div>
                    
                    <!-- Category Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-tag"></i>
                            </span>
                            <input asp-for="Name" class="form-control" placeholder="Enter category name (e.g., Men, Women, Kids)" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <!-- Size System dropdown -->
                    <div class="mb-3">
                        <label asp-for="SizeSystemId" class="form-label fw-bold">Default Size System</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-rulers"></i>
                            </span>
                            <select asp-for="SizeSystemId" asp-items="@ViewBag.SizeSystemList" class="form-select">
                            </select>
                        </div>
                        <span asp-validation-for="SizeSystemId" class="text-danger"></span>
                        <div class="form-text">
                            <i class="bi bi-info-circle"></i>
                            Select which size system this category typically uses (optional)
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="row mt-4">
                        <div class="col-6 col-md-3">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-check-circle"></i> Create
                            </button>
                        </div>
                        <div class="col-6 col-md-3">
                            <a asp-controller="Category" asp-action="Index" class="btn btn-secondary w-100">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- Info Panel -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-question-circle"></i> About Size Systems
                    </h5>
                </div>
                <div class="card-body">
                    <p class="small mb-2">
                        <i class="bi bi-dot text-primary"></i>
                        <strong>Size systems</strong> define what sizes are available for products in this category.
                    </p>
                    
                    <hr class="my-2" />
                    
                    <h6 class="mt-2">Available Size Systems:</h6>
                    @{
                        var sizeSystems = ViewBag.SizeSystemList as IEnumerable<SelectListItem>;
                        if (sizeSystems != null && sizeSystems.Count() > 1)
                        {
                            <ul class="list-unstyled small">
                                @foreach (var item in sizeSystems.Skip(1)) // Skip the "-- None --" option
                                {
                                    <li class="mb-1">
                                        <i class="bi bi-check-circle-fill text-success me-1" style="font-size: 0.8rem;"></i>
                                        @item.Text
                                    </li>
                                }
                            </ul>
                        }
                    }
                    
                    <hr class="my-2" />
                    
                    <p class="small text-muted mb-0">
                        <i class="bi bi-lightbulb"></i>
                        <em>Tip: Categories without size systems can still have products, but variants won't have size options.</em>
                    </p>
                </div>
            </div>
            
            <!-- Example Card -->
            <div class="card mt-3">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0">
                        <i class="bi bi-example"></i> Examples
                    </h6>
                </div>
                <div class="card-body small">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <span class="badge bg-info">Men</span> →
                            <span class="badge bg-light text-dark">Adult Regular</span> (S-XXL)
                        </li>
                        <li class="mb-2">
                            <span class="badge bg-info">Women</span> →
                            <span class="badge bg-light text-dark">Women Regular</span> (XS-XL)
                        </li>
                        <li class="mb-2">
                            <span class="badge bg-info">Kids</span> →
                            <span class="badge bg-light text-dark">Kids</span> (50-176 cm)
                        </li>
                        <li class="mb-2">
                            <span class="badge bg-info">Suits</span> →
                            <span class="badge bg-light text-dark">Adult Suit</span> (44-56)
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-category-create.js" asp-append-version="true"></script>
}