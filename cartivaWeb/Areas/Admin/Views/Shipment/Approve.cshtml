@model Shipment

@{
    ViewData["Title"] = "Approve Shipment";
}

<div class="container mt-4">
    <h2>Approve Shipment for Order #@Model.OrderHeader.Id</h2>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">Order Details</div>
                <div class="card-body">
                    <p><strong>Customer:</strong> @Model.OrderHeader.Name</p>
                    <p><strong>Address:</strong> @Model.OrderHeader.StreetAddress, @Model.OrderHeader.City, @Model.OrderHeader.PostalCode</p>
                    <p><strong>Phone:</strong> @Model.OrderHeader.PhoneNumber</p>
                    <p><strong>Order Total:</strong> @Model.OrderHeader.OrderTotal.ToString("C")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <form asp-action="Approve" method="post">
                <input type="hidden" asp-for="Id" />
                <p>Confirm shipment creation with Bring. A tracking number will be generated automatically.</p>
                <button type="submit" class="btn btn-success">Approve and Create Shipment</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>