## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

############################
# User-specific files
############################
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

############################
# Visual Studio cache/options directory
############################
.vs/

############################
# Build results
############################
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
artifacts/

############################
# .NET Core / .NET
############################
project.lock.json
project.fragment.lock.json
project.assets.json
*.deps.json
*.runtimeconfig.json

############################
# Logs
############################
*.log

############################
# Test Results
############################
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

############################
# Visual Studio profiler
############################
*.psess
*.vsp
*.vspx
*.sap

############################
# MSTest
############################
TestResults/

############################
# NUnit
############################
*.VisualState.xml
TestResult.xml

############################
# Benchmark
############################
BenchmarkDotNet.Artifacts/

############################
# NuGet
############################
*.nupkg
*.snupkg
packages/
!packages/build/
*.nuget.props
*.nuget.targets

############################
# DotNet CLI
############################
.dotnet/

############################
# Entity Framework
############################
*.mdf
*.ldf

############################
# Azure Publish Settings
############################
*.Publish.xml
*.azurePubxml
*.publishsettings
.publish/

############################
# IIS Express
############################
IISExpress/
*.vspscc
*.vssscc

############################
# Resharper
############################
_ReSharper*/
*.ReSharper
*.DotSettings.user

############################
# Rider
############################
.idea/

############################
# VS Code
############################
.vscode/

############################
# Node / Frontend
############################
node_modules/
npm-debug.log
yarn-error.log
dist/
build/

############################
# Web tools
############################
wwwroot/lib/

############################
# Bower
############################
bower_components/

############################
# Docker
############################
docker-compose.vs.debug.g.yml
docker-compose.vs.release.g.yml
docker-compose.override.yml

############################
# OS generated files
############################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

