# Windows Installer
############################
*.cab
*.msi
*.msix
*.msm
*.msp

############################
# SQL Server files
############################
*.ndf
*.ldf
*.mdf

############################
# Backup files
############################
*.bak
*.backup

############################
# Temporary files
############################
*.tmp
*.temp
*.cache
*.pid

############################
# Package Restore
############################
.nuget/
packages/*
!packages/build/

############################
# Visual Studio Code Coverage
############################
*.coverage
*.coveragexml

############################
# Generated files
############################
Generated\ Files/

