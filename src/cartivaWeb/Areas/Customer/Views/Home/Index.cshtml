@using System.Globalization
@using Cartiva.Shared
@using Cartiva.Domain
@model IEnumerable<Product>

@{
    ViewData["Title"] = "Home";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
    var activePromotions = ViewBag.ActivePromotions as List<Promotion> ?? new List<Promotion>();
    var promotedCategoryIds = activePromotions.Select(p => p.CategoryId).ToHashSet();
}

<div class="container-fluid mt-4 px-2">

    <!-- Promotion Banners -->
    @if (activePromotions.Any())
    {
        <div class="promo-banner mb-4 shadow-sm">
            <div class="promo-track">
                <div class="promo-content">
                    @foreach (var promo in activePromotions)
                    {
                        <span class="promo-item">
                            <i class="bi bi-gift"></i>
                            <strong>@promo.DisplayText!</strong>
                            <span class="mx-1">—</span>
                            <span>@promo.Category?.Name</span>
                            <small class="opacity-75 ms-2">
                                <i class="bi bi-clock"></i> Ends @promo.EndDate.ToString("dd MMM yyyy")
                            </small>
                        </span>
                    }
                    @* Duplicate for seamless loop *@
                    @foreach (var promo in activePromotions)
                    {
                        <span class="promo-item">
                            <i class="bi bi-gift"></i>
                            <strong>@promo.DisplayText!</strong>
                            <span class="mx-1">—</span>
                            <span>@promo.Category?.Name</span>
                            <small class="opacity-75 ms-2">
                                <i class="bi bi-clock"></i> Ends @promo.EndDate.ToString("dd MMM yyyy")
                            </small>
                        </span>
                    }
                </div>
            </div>
        </div>

        <style>
            .promo-banner {
                background: linear-gradient(135deg, #198754, #20c997);
                color: white;
                border-radius: 0.5rem;
                overflow: hidden;
                padding: 0.75rem 0;
            }

            .promo-track {
                overflow: hidden;
                position: relative;
            }

            .promo-content {
                display: flex;
                white-space: nowrap;
                animation: promo-scroll 20s linear infinite;
                width: max-content;
            }

            .promo-item {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                padding: 0 2.5rem;
                font-size: 1rem;
            }

            .promo-banner:hover .promo-content {
                animation-play-state: paused;
            }

            @@keyframes promo-scroll {
                0% { transform: translateX(0); }
                100% { transform: translateX(-50%); }
            }
        </style>
    }

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col text-center">
            <h2 class="fw-bold">Our Products</h2>
            <p class="text-muted">Browse our latest products</p>
        </div>
    </div>

    <!-- Product Grid -->
    <div class="row g-3 justify-content-start">
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                // Calculate lowest price from variants
                var lowestPrice = product.Variants != null && product.Variants.Any()
                    ? product.Variants.Min(v => v.Price)
                    : (decimal?)null;

                var promo = activePromotions.FirstOrDefault(p => p.CategoryId == product.CategoryId);

                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="card h-100 shadow-sm position-relative">

                        <!-- Promotion Badge -->
                        @if (promo != null)
                        {
                            <span class="badge bg-success position-absolute top-0 start-0 m-2 px-2 py-1 z-1">
                                <i class="bi bi-gift"></i> @promo.DisplayText
                                <br /><small>Ends @promo.EndDate.ToString("dd MMM")</small>
                            </span>
                        }

                        <!-- Sale Badge -->
                        @if (lowestPrice.HasValue && lowestPrice.Value < 100 && promo == null)
                        {
                            <span class="badge bg-danger position-absolute top-0 end-0 m-2 px-2 py-1">
                                <i class="bi bi-tag"></i> Sale
                            </span>
                        }

                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/no-image.png" : product.ImageUrl)"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;"
                             alt="@product.Name" />

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">@product.Name</h5>
                            <p class="text-muted mb-1"><strong>Brand:</strong> @product.Brand</p>
                            <p class="text-muted mb-1"><strong>Category:</strong> @(product.Category?.Name ?? "No Category")</p>
                            
                            <!-- Price Display -->
                            @if (lowestPrice.HasValue)
                            {
                                <div class="mb-2">
                                    <span class="h5 text-primary fw-bold">@lowestPrice.Value.ToString("C", culture)</span>
                                    <small class="text-muted">
                                        @if (product.Variants.Count() > 1)
                                        {
                                            <span>+ @(product.Variants.Count() - 1) more</span>
                                        }
                                    </small>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-2">
                                    <i class="bi bi-exclamation-circle"></i> No variants available
                                </p>
                            }

                            <p class="card-text small mb-2">
                                @(string.IsNullOrEmpty(product.Description) ? "No description available." : product.Description)
                            </p>

                            <!-- Rating -->
                            @{
                                var productReviews = product.Variants?
                                    .Where(v => v.Reviews != null)
                                    .SelectMany(v => v.Reviews!)
                                    .ToList() ?? new List<Review>();
                                var productAvgRating = productReviews.Any() ? productReviews.Average(r => r.Rating) : 0;
                            }
                            @if (productReviews.Any())
                            {
                                <div class="mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Round(productAvgRating))
                                        {
                                            <i class="bi bi-star-fill text-warning small"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-muted small"></i>
                                        }
                                    }
                                    <small class="text-muted ms-1">(@productReviews.Count)</small>
                                </div>
                            }

                            <!-- View Details -->
                            <a asp-area="Customer"
                                   asp-controller="Home"
                                   asp-action="Details"
                                   asp-route-id="@product.Id"
                                   class="btn btn-dark mt-auto">
                                <i class="bi bi-eye"></i> View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col text-center">
                <p class="text-muted">No products available.</p>
            </div>
        }
    </div>
</div>
