@model Shipment
@using System.Globalization
@using Cartiva.Shared

@{
    ViewData["Title"] = $"Shipment Details #{Model.Id}";
    var culture = CultureInfo.GetCultureInfo("nb-NO");
}

<div class="container mt-4">
    <h2>Shipment #@Model.Id</h2>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">Shipment Information</div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Order ID</dt>
                        <dd class="col-sm-8">@Model.OrderHeader.Id</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8"><span class="badge @SD.GetShipmentStatusBadgeClass(Model.ShipmentStatus)">@Model.ShipmentStatus</span></dd>

                        <dt class="col-sm-4">Tracking Number</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.TrackingNumber) ? "—" : Model.TrackingNumber)</dd>

                        <dt class="col-sm-4">Carrier</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Carrier) ? "—" : Model.Carrier)</dd>

                        <dt class="col-sm-4">Service</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Service) ? "—" : Model.Service)</dd>

                        <dt class="col-sm-4">Shipped Date</dt>
                        <dd class="col-sm-8">@(Model.ShippedDate?.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>

                        <dt class="col-sm-4">Delivered Date</dt>
                        <dd class="col-sm-8">@(Model.DeliveredDate?.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-success text-white">Order Information</div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Customer</dt>
                        <dd class="col-sm-8">@Model.OrderHeader.Name</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.OrderHeader.ApplicationUser?.Email</dd>

                        <dt class="col-sm-4">Phone</dt>
                        <dd class="col-sm-8">@Model.OrderHeader.PhoneNumber</dd>

                        <dt class="col-sm-4">Address</dt>
                        <dd class="col-sm-8">
                            @Model.OrderHeader.StreetAddress,<br />
                            @Model.OrderHeader.PostalCode @Model.OrderHeader.City@(!string.IsNullOrEmpty(Model.OrderHeader.State) ? $", {Model.OrderHeader.State}" : "")
                        </dd>

                        <dt class="col-sm-4">Order Total</dt>
                        <dd class="col-sm-8">@Model.OrderHeader.OrderTotal.ToString("C", culture)</dd>

                        <dt class="col-sm-4">Order Status</dt>
                        <dd class="col-sm-8"><span class="badge @SD.GetOrderStatusBadgeClass(Model.OrderHeader.OrderStatus)">@Model.OrderHeader.OrderStatus</span></dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        @if (Model.ShipmentStatus == SD.ShipmentStatusPendingApproval)
        {
            <a asp-action="Approve" asp-route-id="@Model.Id" class="btn btn-success">Approve</a>
        }
        @if (Model.ShipmentStatus != SD.ShipmentStatusShipped && Model.ShipmentStatus != SD.ShipmentStatusDelivered && Model.ShipmentStatus != SD.ShipmentStatusCancelled)
        {
            <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-danger">Cancel</a>
        }
        <a  asp-controller="Shipment" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    </div>
</div>