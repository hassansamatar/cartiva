@model IEnumerable<Promotion>

@{
    ViewData["Title"] = "Promotions";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-gift"></i> Promotions</h2>
        <a asp-action="Upsert" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> New Promotion
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Promotion</th>
                    <th>Category</th>
                    <th>Offer</th>
                    <th>Duration</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var promo in Model)
                {
                    <tr>
                        <td>
                            <strong>@promo.Name</strong>
                            @if (!string.IsNullOrEmpty(promo.Description))
                            {
                                <br /><small class="text-muted">@promo.Description</small>
                            }
                        </td>
                        <td><span class="badge bg-info">@promo.Category?.Name</span></td>
                        <td>
                            <span class="badge bg-success fs-6">
                                Buy @promo.BuyQuantity Get @promo.GetQuantity Free
                            </span>
                        </td>
                        <td>
                            <small>
                                @promo.StartDate.ToString("dd MMM yyyy") — @promo.EndDate.ToString("dd MMM yyyy")
                            </small>
                        </td>
                        <td>
                            @if (promo.IsCurrentlyActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else if (promo.IsActive && DateTime.Now < promo.StartDate)
                            {
                                <span class="badge bg-warning text-dark">Scheduled</span>
                            }
                            else if (promo.IsActive && DateTime.Now > promo.EndDate)
                            {
                                <span class="badge bg-secondary">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Upsert" asp-route-id="@promo.Id" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleStatus" asp-route-id="@promo.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-@(promo.IsActive ? "warning" : "success")">
                                        <i class="bi bi-@(promo.IsActive ? "pause" : "play")"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@promo.Id" method="post" class="d-inline btn-swal-confirm-form"
                                      data-swal-title="Delete this promotion?"
                                      data-swal-text="This action cannot be undone.">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-gift" style="font-size: 3rem; color: #6c757d;"></i>
            <h5 class="mt-3">No promotions yet</h5>
            <a asp-action="Upsert" class="btn btn-primary mt-2">Create Your First Promotion</a>
        </div>
    }
</div>
